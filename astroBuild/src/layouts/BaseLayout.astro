---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import { SITE_URL } from "../utils/config";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title = "Paper-Guides",
  description = "Free exam preparation resources — Past Papers, Notes, Question Generator, and more.",
  ogImage = `${SITE_URL ?? "https://paperguides.org"}/images/opg_paper_guides.png`,
  canonical = `${SITE_URL ?? "https://paperguides.org"}${Astro.url.pathname}`,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Paper Guides" />
    <meta property="og:url" content={canonical} />
    <link rel="icon" href="/images/logo.ico" />

    <!-- Google Ads -->
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8879795771404007"
      crossorigin="anonymous"></script>

    <!-- Umami Analytics -->
    <script
      defer
      is:inline
      src="https://analytics.chaulagainrupak.com.np/script.js"
      data-website-id="576bcb5b-cf9d-43c9-bdf4-ee8d71f1bf49"
      data-auto-track="true"></script>
  </head>
  <body class="flex flex-col min-h-screen">
    <Nav />
    <ThemeToggle />
    <main class="flex-grow">
      <slot />
    </main>
    <Footer />
  </body>
</html>
