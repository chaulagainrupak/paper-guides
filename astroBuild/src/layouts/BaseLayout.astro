---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import ThemeToggle from "../components/ThemeToggle.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title = "Paper-Guides",
  description = "Free exam preparation resources — Past Papers, Notes, Question Generator, and more.",
  ogImage = `${SITE_URL ?? "https://paperguides.org"}/images/opg_paper_guides.png`,
  canonical = `${SITE_URL ?? "https://paperguides.org"}${Astro.url.pathname}`,
} = Astro.props;

import { SITE_URL, UMAMI_WEBSITE_ID, UMAMI_URL } from "../utils/config";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Paper Guides" />
    <meta property="og:url" content={canonical} />
    <link rel="icon" href="/images/logo.ico" />
    <meta name="robots" content="index, follow" />

    <!-- Google Ads -->
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8879795771404007"
      crossorigin="anonymous"></script>

    <!-- Umami Analytics -->
    <script
      defer
      is:inline
      src={`${UMAMI_URL}/script.js`}
      data-website-id={UMAMI_WEBSITE_ID}
      data-auto-track="true"></script>

    <!-- KaTeX for maths rendering -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.40/dist/katex.min.css"
      integrity="sha384-mON/ih42JsLUsSfSt0ZgICEtv3P1FSm/qGKVl2cfuvShhc8Q91I7HhJFWtoKlq3k"
      crossorigin="anonymous"
    />
    <!-- KaTeX JS — deferred to speed up page rendering -->
    <script
      is:inline
      src="https://cdn.jsdelivr.net/npm/katex@0.16.40/dist/katex.min.js"
      integrity="sha384-KVukqdeLrVnRMhtuS+JxbqQzFmHDyzAWj//smK5ksfZKEPz0hSvLyYvAUE9yJuzF"
      crossorigin="anonymous"></script>

    <!-- marked for Markdown rendering -->
    <script
      is:inline
      src="https://cdn.jsdelivr.net/npm/marked@12.0.0/marked.min.js"
      crossorigin="anonymous"></script>
  </head>
  <body class="flex flex-col min-h-screen">
    <Nav />
    <ThemeToggle />
    <main class="flex-grow">
      <slot />
    </main>
    <Footer />
  </body>
</html>