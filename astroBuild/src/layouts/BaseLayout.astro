---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { SITE_URL, UMAMI_WEBSITE_ID, UMAMI_URL } from "../utils/config";

interface Props {
    title?: string;
    description?: string;
    ogImage?: string;
    keywords?: string[];
    noIndex?: boolean;
    lastUpdated?: string | Date;
}

const cleanPath =
    Astro.url.pathname !== "/" && Astro.url.pathname.endsWith("/")
        ? Astro.url.pathname.slice(0, -1)
        : Astro.url.pathname;

const canonical = `${SITE_URL ?? "https://paperguides.org"}${cleanPath}`;

const {
    title = "Paper Guides",
    description = "Free exam preparation resources — Past Papers, Notes, Question Generator, and more.",
    ogImage = `${SITE_URL ?? "https://paperguides.org"}/images/opg_paper_guides.png`,
    keywords = [],
    noIndex = false,
    lastUpdated,
} = Astro.props;

const resolvedLastUpdated = lastUpdated ? new Date(lastUpdated) : new Date();
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />

        <title>{title}</title>
        <meta name="description" content={description} />
        <meta name="author" content="Paper Guides" />
        <meta
            name="robots"
            content={noIndex ? "noindex, nofollow" : "index, follow"}
        />
        {
            keywords.length > 0 && (
                <meta
                    name="keywords"
                    content={
                        "Paper Guides, free past papers, study notes," +
                        keywords.join(", ")
                    }
                />
            )
        }
        <link rel="canonical" href={canonical} />

        <meta
            name="last-modified"
            content={resolvedLastUpdated.toISOString()}
        />
        <meta
            http-equiv="last-modified"
            content={resolvedLastUpdated.toUTCString()}
        />

        <!-- Open Graph -->
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={ogImage} />
        <meta property="og:type" content="website" />
        <meta property="og:site_name" content="Paper Guides" />
        <meta property="og:url" content={canonical} />
        <meta property="og:locale" content="en_US" />

        <!-- Twitter / X -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImage} />

        <link rel="icon" href="/images/logo.ico" />
        <meta name="theme-color" content="#4ade80" />
        <link rel="sitemap" type="application/xml" href="/sitemap.xml" />

        <script defer src="/scripts/katex.min.js"></script>
        <script defer src="/scripts/auto-render.min.js"></script>
        <script defer src="/scripts/marked.min.js"></script>

        <!-- Umami Analytics -->
        <script
            async
            is:inline
            src={`${UMAMI_URL}/script.js`}
            data-website-id={UMAMI_WEBSITE_ID}
            data-auto-track="true"></script>
    </head>
    <body class="flex flex-col min-h-screen">
        <!-- We're making peanuts with this while making the site slower :( maybe once we have a large audience we can use this -->

        <!-- <script>
            window.addEventListener("load", () => {
                const s = document.createElement("script");
                s.src =
                    "https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8879795771404007";
                s.async = true;
                s.crossOrigin = "anonymous";
                document.body.appendChild(s);
            });
        </script> -->

        <Nav />
        <main class="flex-grow">
            <slot />
        </main>
        <Footer />
    </body>
</html>
