
---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import { SITE_URL } from "../utils/config";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title = "Paper-Guides",
  description = "Free exam preparation resources — Past Papers, Notes, Question Generator, and more.",
  ogImage = `${SITE_URL ?? "https://paperguides.org"}/images/opg_paper_guides.png`,
  canonical,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Paper Guides" />
    <link rel="icon" href="/images/logo.ico" />

    <!-- Google Ads -->
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8879795771404007"
      crossorigin="anonymous"></script>

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-2B6JNCMRZ4"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-2B6JNCMRZ4");
      gtag("config", "G-SZDFC8YDWK");
    </script>
  </head>
  <body class="flex flex-col min-h-screen">
    <Nav />
    <ThemeToggle />
    <main class="flex-grow">
      <slot />
    </main>
    <Footer />
  </body>
</html>

