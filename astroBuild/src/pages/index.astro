---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Paper-Guides | Past Papers, Notes & Question Generator"
  description="Free exam preparation resources — Past Papers, Notes, Question Generator for O-Level, A-Levels, NEB / TU / IOE and more."
>
  <!-- JSON-LD structured data for Google rich results -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "PaperGuides",
      "url": "https://paperguides.org",
      "description": "Free past papers, study notes, and question generator for CAIE A Levels and Kathmandu University. Open-source, community-maintained, made in Nepal.",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://paperguides.org/questions?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    }
  </script>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "EducationalOrganization",
      "name": "PaperGuides",
      "url": "https://paperguides.org",
      "description": "Free exam preparation platform for A Level and university students in Nepal and globally.",
      "foundingCountry": "NP",
      "audience": {
        "@type": "EducationalAudience",
        "educationalRole": "student"
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Study Resources",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Course",
              "name": "CAIE A Level Past Papers",
              "description": "Past papers for Physics 9702, Mathematics 9709, Chemistry 9701, Biology 9700, Computer Science 9618, Economics 9708 and more."
            },
            "price": "0",
            "priceCurrency": "USD"
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Course",
              "name": "Kathmandu University Past Papers",
              "description": "Past papers for KU bachelors programmes including BBA, BCA, BIM, BE Computer, BE Civil, BE Electrical, BSc Biotechnology, BSc Pharmacy and more."
            },
            "price": "0",
            "priceCurrency": "USD"
          }
        ]
      }
    }
  </script>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": "CAIE A Level Subjects on PaperGuides",
      "url": "https://paperguides.org/pastpapers",
      "itemListElement": [
        {"@type":"ListItem","position":1,"name":"Physics 9702","url":"https://paperguides.org/subjects/a-levels/physics-9702"},
        {"@type":"ListItem","position":2,"name":"Mathematics 9709","url":"https://paperguides.org/subjects/a-levels/mathematics-9709"},
        {"@type":"ListItem","position":3,"name":"Chemistry 9701","url":"https://paperguides.org/subjects/a-levels/chemistry-9701"},
        {"@type":"ListItem","position":4,"name":"Biology 9700","url":"https://paperguides.org/subjects/a-levels/biology-9700"},
        {"@type":"ListItem","position":5,"name":"Computer Science 9618","url":"https://paperguides.org/subjects/a-levels/computer-science-9608"},
        {"@type":"ListItem","position":6,"name":"Economics 9708","url":"https://paperguides.org/subjects/a-levels/economics-9708"},
        {"@type":"ListItem","position":7,"name":"Business 9609","url":"https://paperguides.org/subjects/a-levels/business-9609"},
        {"@type":"ListItem","position":8,"name":"English Literature 9695","url":"https://paperguides.org/subjects/a-levels/english-literature-9695"},
        {"@type":"ListItem","position":9,"name":"History 9389","url":"https://paperguides.org/subjects/a-levels/history-9389"},
        {"@type":"ListItem","position":10,"name":"Geography 9696","url":"https://paperguides.org/subjects/a-levels/geography-9696"}
      ]
    }
  </script>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": "Kathmandu University Subjects on PaperGuides",
      "url": "https://paperguides.org/subjects/kathmandu-university",
      "itemListElement": [
        {"@type":"ListItem","position":1,"name":"BCA — Computer Applications","url":"https://paperguides.org/subjects/kathmandu-university/comp-105-computer-applications"},
        {"@type":"ListItem","position":2,"name":"Programming Concepts","url":"https://paperguides.org/subjects/kathmandu-university/comp-115-programming-concepts"},
        {"@type":"ListItem","position":3,"name":"Database Management Systems","url":"https://paperguides.org/subjects/kathmandu-university/comp-232-database-management-systems"},
        {"@type":"ListItem","position":4,"name":"Operating Systems","url":"https://paperguides.org/subjects/kathmandu-university/comp-307-operating-systems"},
        {"@type":"ListItem","position":5,"name":"Algorithms and Complexity","url":"https://paperguides.org/subjects/kathmandu-university/comp-314-algorithms-and-complexity"},
        {"@type":"ListItem","position":6,"name":"Artificial Intelligence","url":"https://paperguides.org/subjects/kathmandu-university/comp-472-artificial-intelligence"},
        {"@type":"ListItem","position":7,"name":"Machine Learning","url":"https://paperguides.org/subjects/kathmandu-university/comp-473-machine-learning"},
        {"@type":"ListItem","position":8,"name":"Calculus and Linear Algebra","url":"https://paperguides.org/subjects/kathmandu-university/math-101-calculus-and-linear-algebra"},
        {"@type":"ListItem","position":9,"name":"Biotechnology","url":"https://paperguides.org/subjects/kathmandu-university/biot-101-introduction-to-biotechnology"},
        {"@type":"ListItem","position":10,"name":"Pharmacy","url":"https://paperguides.org/subjects/kathmandu-university/phar-111-pharmaceutical-chemistry-i"},
        {"@type":"ListItem","position":11,"name":"Thermodynamics","url":"https://paperguides.org/subjects/kathmandu-university/meeg-141-thermodynamics-i"},
        {"@type":"ListItem","position":12,"name":"Control Systems","url":"https://paperguides.org/subjects/kathmandu-university/eeeg-331-control-systems"}
      ]
    }
  </script>

  <div
    class="mt-[64px] min-h-[calc(100vh-64px)] grid grid-cols-1 md:grid-cols-[3fr_1fr] gap-0 relative overflow-hidden"
  >
    <!-- Scattered decorative icons -->
    <i
      class="ph-fill ph-books absolute pointer-events-none select-none text-[var(--muted)] opacity-[0.08] text-lg rotate-[-15deg]"
      style="top:11%; left:3%;"></i>
    <i
      class="ph-fill ph-pencil-simple absolute pointer-events-none select-none text-[var(--muted)] opacity-[0.07] text-2xl rotate-[12deg]"
      style="top:22%; left:88%;"></i>
    <i
      class="ph-fill ph-graduation-cap absolute pointer-events-none select-none text-[var(--muted)] opacity-[0.09] text-base rotate-[8deg]"
      style="top:62%; left:5%;"></i>
    <i
      class="ph-fill ph-calculator absolute pointer-events-none select-none text-[var(--muted)] opacity-[0.07] text-xl rotate-[-22deg]"
      style="top:78%; left:77%;"></i>
    <i
      class="ph-fill ph-flask absolute pointer-events-none select-none text-[var(--muted)] opacity-[0.06] text-sm rotate-[5deg]"
      style="top:40%; left:52%;"></i>
    <i
      class="ph-fill ph-brain absolute pointer-events-none select-none text-[var(--muted)] opacity-[0.07] text-2xl rotate-[-8deg]"
      style="top:88%; left:18%;"></i>
    <i
      class="ph-fill ph-clock absolute pointer-events-none select-none text-[var(--muted)] opacity-[0.06] text-base rotate-[18deg]"
      style="top:14%; left:42%;"></i>
    <i
      class="ph-fill ph-chart-line absolute pointer-events-none select-none text-[var(--muted)] opacity-[0.06] text-lg rotate-[-5deg]"
      style="top:55%; left:63%;"></i>

    <!-- HERO LEFT -->
    <div
      class="w-full flex flex-col justify-center gap-6 md:px-25 px-5 py-12 md:py-0"
    >
      <!-- Hero tag -->
      <div
        class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full border border-[var(--border-subtle)] bg-[var(--accent)]/10 text-[var(--muted)] text-[0.7rem] font-sans font-semibold uppercase tracking-widest w-fit"
      >
        <i class="ph-fill ph-dot-outline"></i>Free
        <i class="ph-fill ph-dot-outline"></i>Open Source
      </div>

      <h1 class="font-serif text-[clamp(52px,6.5vw,90px)]/[0.92] font-bold">
        Study <br />
        <em class="text-[var(--accent)]">smarter,</em>
        <br />
        <em class="font-normal text-[var(--muted)]"> not harder. </em>
      </h1>

      <p
        class="md:max-w-[50%] text-[var(--muted)] font-sans text-sm leading-relaxed"
      >
        Past papers, quality notes, per-topic question generator, Q&A repository
        — all free, made by students who've been there.
      </p>

      <div class="flex flex-col sm:flex-row gap-3 w-full sm:w-auto">
        <a
          href="/pastpapers"
          class="group w-full sm:w-auto rounded-full px-6 py-3 flex items-center justify-center gap-2
                 bg-[var(--cta-button)] text-[var(--cta-text)] shadow-lg font-sans text-sm font-medium
                 transition-all duration-300 ease-out hover:shadow-2xl hover:-translate-y-0.5 hover:scale-[1.02]"
        >
          Browse Past Papers
          <i
            class="ph-fill ph-arrow-right transition-transform duration-300 group-hover:translate-x-1"
          ></i>
        </a>
        <a
          href="/generator"
          class="group w-full sm:w-auto rounded-full px-6 py-3 flex items-center justify-center
                 border border-[var(--border-subtle)] text-[var(--color-text)] font-sans text-sm font-medium
                 transition-all duration-300 ease-out shadow-sm
                 hover:bg-[var(--muted)]/10 hover:-translate-y-0.5 hover:scale-[1.02]"
        >
          Try Generator
        </a>
      </div>

      <!-- Stats -->
      <div class="flex gap-6 mt-2 border-t border-[var(--border-subtle)] pt-5">
        <a
          href="/pastpapers"
          class="border-r border-[var(--border-subtle)] pr-6 flex flex-col items-center text-center cursor-pointer group"
        >
          <div
            class="font-serif-body text-3xl group-hover:text-[var(--accent)] transition-colors"
          >
            2
          </div>
          <div class="font-sans text-xs text-[var(--muted)] mt-0.5">
            Boards Covered
          </div>
        </a>
        <div
          class="border-r border-[var(--border-subtle)] pr-6 flex flex-col items-center text-center"
        >
          <div class="font-serif-body text-3xl">~150+</div>
          <div class="font-sans text-xs text-[var(--muted)] mt-0.5">
            A Level & KU Subjects
          </div>
        </div>
        <a
          href="/about"
          class="flex flex-col items-center text-center cursor-pointer group"
        >
          <div
            class="font-serif-body text-3xl group-hover:text-[var(--accent)] transition-colors"
          >
            100%
          </div>
          <div class="font-sans text-xs text-[var(--muted)] mt-0.5">
            Free, always
          </div>
        </a>
      </div>
    </div>

    <!-- SIDEBAR -->
    <div
      class="relative overflow-hidden bg-[var(--sidebar-bg)] flex flex-col justify-center w-full h-full px-0 py-8 md:py-0 gap-0 md:border-l border-[var(--border-subtle)]"
    >
      <!-- Gradient wash -->
      <div
        class="absolute inset-0 pointer-events-none z-0"
        style="background: linear-gradient(160deg, color-mix(in srgb, var(--accent) 6%, transparent), transparent 55%, color-mix(in srgb, var(--french-blue) 5%, transparent));"
      >
      </div>

      <!-- Grid texture -->
      <div
        class="absolute inset-0 pointer-events-none opacity-35 z-0"
        style="background-image: linear-gradient(var(--border-subtle) 1px, transparent 1px), linear-gradient(90deg, var(--border-subtle) 1px, transparent 1px); background-size: 28px 28px;"
      >
      </div>

      <!-- Ghost deco icons -->
      <i
        class="ph-fill ph-exam absolute pointer-events-none select-none text-[var(--color-text)] opacity-[0.04] text-[6rem] rotate-[20deg] z-0"
        style="bottom:12%; right:-8%;"></i>
      <i
        class="ph-fill ph-books absolute pointer-events-none select-none text-[var(--color-text)] opacity-[0.04] text-[4rem] rotate-[-15deg] z-0"
        style="top:8%; left:-5%;"></i>
      <i
        class="ph-fill ph-star-four absolute pointer-events-none select-none text-[var(--color-text)] opacity-[0.05] text-[3rem] rotate-[8deg] z-0"
        style="top:44%; right:5%;"></i>

      <!-- Inner content -->
      <div class="relative z-10 flex flex-col h-full justify-center">
        <!-- Header -->
        <div class="flex items-center gap-2 px-5 pt-5 pb-3">
          <i
            class="ph-fill ph-sparkle text-[var(--accent)] opacity-60 text-[0.75rem]"
          ></i>
          <h2
            class="font-serif text-[0.7rem] font-bold tracking-[0.12em] uppercase text-[var(--muted)] m-0"
          >
            Start Here
          </h2>
          <div class="flex-1 h-px bg-[var(--border-subtle)]"></div>
          <div
            class="w-1.5 h-1.5 rounded-full bg-[var(--accent)] opacity-50 shrink-0"
          >
          </div>
        </div>

        <!-- Past Papers -->
        <a
          href="/pastpapers"
          class="group relative flex items-start gap-3 p-5 cursor-pointer border-b border-[var(--border-subtle)]
                 transition-all duration-200 hover:bg-[var(--sidebar-hover)]
                 before:content-[''] before:absolute before:left-0 before:top-0 before:bottom-0 before:w-0.5
                 before:bg-[var(--accent)] before:opacity-0 before:transition-opacity before:duration-200
                 hover:before:opacity-100"
        >
          <div class="sidebar-icon-wrap sidebar-icon-accent shrink-0 mt-0.5">
            <i class="ph-fill ph-exam text-[var(--accent)]"></i>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="font-semibold text-sm text-[var(--color-text)]">
              Past Papers
            </h3>
            <p class="text-xs text-[var(--muted)] mt-0.5 leading-relaxed">
              CAIE A Levels and KU Bachelors, organized by subject and year.
            </p>
            <div
              class="inline-flex items-center gap-1 mt-1 text-[0.6rem] font-semibold uppercase tracking-[0.06em] px-2 py-0.5 rounded-full bg-[var(--accent)]/10 text-[var(--accent)]"
            >
              <i class="ph-fill ph-file-text text-[0.6rem]"></i>
              A Levels · KU
            </div>
          </div>
          <i
            class="ph-fill ph-arrow-right text-[var(--muted)] text-sm shrink-0 mt-1 transition-all duration-300 group-hover:translate-x-0.5 group-hover:text-[var(--accent)]"
          ></i>
        </a>

        <!-- Question Generator -->
        <a
          href="/generator"
          class="group relative flex items-start gap-3 p-5 cursor-pointer border-b border-[var(--border-subtle)]
                 transition-all duration-200 hover:bg-[var(--sidebar-hover)]
                 before:content-[''] before:absolute before:left-0 before:top-0 before:bottom-0 before:w-0.5
                 before:bg-yellow-600 before:opacity-0 before:transition-opacity before:duration-200
                 hover:before:opacity-100"
        >
          <div class="sidebar-icon-wrap sidebar-icon-yellow shrink-0 mt-0.5">
            <i class="ph-fill ph-lightning text-yellow-600"></i>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="font-semibold text-sm text-[var(--color-text)]">
              Question Generator
            </h3>
            <p class="text-xs text-[var(--muted)] mt-0.5 leading-relaxed">
              Custom practice sets by topic, difficulty, and component.
            </p>
            <div
              class="inline-flex items-center gap-1 mt-1 text-[0.6rem] font-semibold uppercase tracking-[0.06em] px-2 py-0.5 rounded-full bg-yellow-500/10 text-yellow-700 dark:text-yellow-400"
            >
              <i class="ph-fill ph-sliders text-[0.6rem]"></i>
              Topic wise
            </div>
          </div>
          <i
            class="ph-fill ph-arrow-right text-[var(--muted)] text-sm shrink-0 mt-1 transition-all duration-300 group-hover:translate-x-0.5 group-hover:text-yellow-600"
          ></i>
        </a>

        <!-- Study Notes -->
        <a
          href="/notes"
          class="group relative flex items-start gap-3 p-5 cursor-pointer border-b border-[var(--border-subtle)]
                 transition-all duration-200 hover:bg-[var(--sidebar-hover)]
                 before:content-[''] before:absolute before:left-0 before:top-0 before:bottom-0 before:w-0.5
                 before:bg-[var(--jungle-green)] before:opacity-0 before:transition-opacity before:duration-200
                 hover:before:opacity-100"
        >
          <div class="sidebar-icon-wrap sidebar-icon-green shrink-0 mt-0.5">
            <i class="ph-fill ph-notebook text-[var(--jungle-green)]"></i>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="font-semibold text-sm text-[var(--color-text)]">
              Study Notes
            </h3>
            <p class="text-xs text-[var(--muted)] mt-0.5 leading-relaxed">
              Curated notes by students who've sat the exams.
            </p>
            <div
              class="inline-flex items-center gap-1 mt-1 text-[0.6rem] font-semibold uppercase tracking-[0.06em] px-2 py-0.5 rounded-full bg-[var(--jungle-green)]/10 text-[var(--jungle-green)]"
            >
              <i class="ph-fill ph-users text-[0.6rem]"></i>
              Student Made
            </div>
          </div>
          <i
            class="ph-fill ph-arrow-right text-[var(--muted)] text-sm shrink-0 mt-1 transition-all duration-300 group-hover:translate-x-0.5 group-hover:text-[var(--jungle-green)]"
          ></i>
        </a>

        <!-- Questions -->
        <a
          href="/questions"
          class="group relative flex items-start gap-3 p-5 cursor-pointer border-b border-[var(--border-subtle)]
                 transition-all duration-200 hover:bg-[var(--sidebar-hover)]
                 before:content-[''] before:absolute before:left-0 before:top-0 before:bottom-0 before:w-0.5
                 before:bg-[var(--french-blue)] before:opacity-0 before:transition-opacity before:duration-200
                 hover:before:opacity-100"
        >
          <div class="sidebar-icon-wrap sidebar-icon-blue shrink-0 mt-0.5">
            <i class="ph-fill ph-chat-circle-dots text-[var(--french-blue)]"
            ></i>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="font-semibold text-sm text-[var(--color-text)]">
              Questions
            </h3>
            <p class="text-xs text-[var(--muted)] mt-0.5 leading-relaxed">
              Search curated questions across all subjects and topics.
            </p>
            <div
              class="inline-flex items-center gap-1 mt-1 text-[0.6rem] font-semibold uppercase tracking-[0.06em] px-2 py-0.5 rounded-full bg-[var(--french-blue)]/10 text-[var(--french-blue)]"
            >
              <i class="ph-fill ph-magnifying-glass text-[0.6rem]"></i>
              Searchable
            </div>
          </div>
          <i
            class="ph-fill ph-arrow-right text-[var(--muted)] text-sm shrink-0 mt-1 transition-all duration-300 group-hover:translate-x-0.5 group-hover:text-[var(--french-blue)]"
          ></i>
        </a>

        <!-- Sidebar footer badge -->
        <div
          class="flex items-center gap-2 px-5 py-3.5 border-t border-[var(--border-subtle)]"
        >
          <i
            class="ph-fill ph-shield-check text-[var(--accent)] opacity-70 text-xs"
          ></i>
          <span
            class="text-[0.65rem] font-sans text-[var(--muted)] tracking-[0.04em]"
            >Free forever</span
          >
          <div class="ml-auto flex gap-1 opacity-30">
            <i class="ph-fill ph-star text-[0.6rem] text-[var(--accent)]"></i>
            <i class="ph-fill ph-star text-[0.6rem] text-[var(--accent)]"></i>
            <i class="ph-fill ph-star text-[0.6rem] text-[var(--accent)]"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- SECOND SECTION -->
  <div class="overflow-hidden">
    <style>
      .marquee-wrap {
        width: 100%;
        overflow: hidden;
        position: relative;
      }
      .marquee-inner {
        display: flex;
        width: max-content;
        animation: marquee 20s linear infinite;
      }
      @keyframes marquee {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
      }
    </style>

    <div class="marquee-wrap bg-[#242424]">
      <div class="marquee-inner h-fit p-2 text-[#e2e0dc]">
        <span class="marquee-item text-xl px-3 italic text-medium font-serif opacity-60"><i class="ph-fill ph-flask"></i> Physics 9702</span>
        <span class="marquee-item text-xl px-3 italic text-medium font-serif opacity-60"><i class="ph-fill ph-calculator"></i> Mathematics 9709</span>
        <span class="marquee-item text-xl px-3 italic text-medium font-serif opacity-60"><i class="ph-fill ph-microscope"></i> Chemistry 9701</span>
        <span class="marquee-item text-xl px-3 italic text-medium font-serif opacity-60"><i class="ph-fill ph-heart"></i> Biology 9700</span>
        <span class="marquee-item text-xl px-3 italic text-medium font-serif opacity-60"><i class="ph-fill ph-code"></i> Computer Science 9618</span>
        <span class="marquee-item text-xl px-3 italic text-medium font-serif opacity-60"><i class="ph-fill ph-chart-bar"></i> Economics 9708</span>
        <span class="marquee-item text-xl px-3 italic text-medium font-serif opacity-60"><i class="ph-fill ph-graduation-cap"></i> BBA 101</span>
        <span class="marquee-item text-xl px-3 italic text-medium font-serif opacity-60"><i class="ph-fill ph-books"></i> BCA 101</span>
        <span class="marquee-item text-xl px-3 italic text-medium font-serif opacity-60"><i class="ph-fill ph-notebook"></i> BIM 101</span>
        <!-- duplicate for seamless loop -->
        <span class="marquee-item text-xl px-3 italic text-medium font-serif opacity-60"><i class="ph-fill ph-flask"></i> Physics 9702</span>
        <span class="marquee-item text-xl px-3 italic text-medium font-serif opacity-60"><i class="ph-fill ph-calculator"></i> Mathematics 9709</span>
        <span class="marquee-item text-xl px-3 italic text-medium font-serif opacity-60"><i class="ph-fill ph-microscope"></i> Chemistry 9701</span>
        <span class="marquee-item text-xl px-3 italic text-medium font-serif opacity-60"><i class="ph-fill ph-heart"></i> Biology 9700</span>
        <span class="marquee-item text-xl px-3 italic text-medium font-serif opacity-60"><i class="ph-fill ph-code"></i> Computer Science 9618</span>
        <span class="marquee-item text-xl px-3 italic text-medium font-serif opacity-60"><i class="ph-fill ph-chart-bar"></i> Economics 9708</span>
        <span class="marquee-item text-xl px-3 italic text-medium font-serif opacity-60"><i class="ph-fill ph-graduation-cap"></i> BBA 101</span>
        <span class="marquee-item text-xl px-3 italic text-medium font-serif opacity-60"><i class="ph-fill ph-books"></i> BCA 101</span>
        <span class="marquee-item text-xl px-3 italic text-medium font-serif opacity-60"><i class="ph-fill ph-notebook"></i> BIM 101</span>
      </div>
    </div>

    <!-- A LEVELS -->
    <div class="bg-[#242424] text-[#e2e0dc] p-5 px-30 max-sm:px-5">
      <span class="italic font-serif text-xs font-bold text-[var(--accent)] opacity-80">A Level &mdash; CAIE</span>
      <h3 class="text-4xl sm:text-5xl font-serif font-bold mb-4">
        Pick Your <span class="text-[var(--accent)] italic">Subject</span>
