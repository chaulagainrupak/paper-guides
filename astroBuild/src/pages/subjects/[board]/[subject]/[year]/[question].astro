---
import BaseLayout from "../../../../../layouts/BaseLayout.astro";
import PaperViewerClient from "../../../../../components/PaperViewerClient";
import { getPaperIndex } from "../../../../../utils/paperIndex";

interface Params {
    board: string;
    subject: string;
    year: string;
    question: string;
}
const { board, subject, year, question } = Astro.params as unknown as Params;

const index = await getPaperIndex();

export async function getStaticPaths() {
    const index = await getPaperIndex();

    const paths: {
        params: {
            board: string;
            subject: string;
            year: string;
            question: string;
        };
    }[] = [];

    for (const board of Object.keys(index)) {
        const subjects = index[board];
        for (const subject of Object.keys(subjects)) {
            const subjectData = subjects[subject];
            const years = subjectData.years ?? {};
            for (const year of Object.keys(years)) {
                const questions = years[year];
                for (const question of questions) {
                    paths.push({ params: { board, subject, year, question } });
                }
            }
        }
    }

    return paths;
}
const subjectData = index?.[board]?.[subject];

const realSubjectName = subjectData?.name ?? subject.replace(/-/g, " ");

const boardNameMap = {
    "a-levels": "A Levels",
    "kathmandu-university": "Kathmandu University",
};

const boardParamMap = {
    "a-levels": "a levels",
    "kathmandu-university": "ku",
};

// @ts-ignore
const apiBoardName = boardNameMap[board] ?? board;
// @ts-ignore
const boardParam = boardParamMap[board] ?? board;

/* parse slug */

let component = "";
let session = "";
let type = "";
let insert = false;
let semester = "";

if (boardParam === "ku") {
    const semesterMatch = question.match(/semester-\d+/i);
    semester = semesterMatch ? semesterMatch[0].replace("-", " ") : "";
} else {
    insert = question.includes("insert-paper");

    const clean = question.replace("-insert-paper", "");

    type = clean.includes("mark-scheme") ? "ms" : "qp";

    const parts = clean.split("-");

    component = parts[parts.length - 4];
    session = `${parts[parts.length - 2]}-${parts[parts.length - 1]}`;
}

const paperName = question.replace(/-/g, " ");

const boardDisplayName =
    board === "a-levels"
        ? "A Levels"
        : board === "kathmandu-university"
          ? "Kathmandu University"
          : board;
---

<BaseLayout
    title={`${paperName} | Paper Guides`}
    description={`Download ${paperName} past paper and mark scheme for ${realSubjectName} (${apiBoardName}) ${year}. Practice real exam questions and improve exam preparation.`}
>
    <div class="mt-[64px] min-h-[calc(100vh-64px)] flex flex-col">
        <div class="bg-[#242424] text-[#f7f7f7]">
            <div
                class="py-8 md:py-12 md:px-20 px-5 grid grid-cols-1 md:grid-cols-2 gap-12 items-center"
            >
                <div class="flex flex-col justify-center">
                    <div class="w-full">
                        <span
                            class="text-[var(--muted)] text-xs flex items-center gap-1 flex-wrap"
                        >
                            <a href="/"><i class="ph-fill ph-house"></i> Home</a
                            > /
                            <a href="/pastpapers"
                                ><i class="ph-fill ph-exam"></i> Past Papers</a
                            > /
                            <a href={`/subjects/${board}`}
                                ><i class="ph-fill ph-book"></i>
                                {boardDisplayName}</a
                            > /
                            <a href={`/subjects/${board}/${subject}`}
                                ><i class="ph-fill ph-books"></i>
                                {realSubjectName}</a
                            > /
                            <a href={`/subjects/${board}/${subject}/${year}`}
                                ><i class="ph-fill ph-file"></i> {year}</a
                            > /
                            <span
                                ><i class="ph-fill ph-file-text"></i>
                                {paperName}</span
                            >
                        </span>
                    </div>

                    <h1 class="font-serif font-bold text-2xl md:text-4xl">
                        Paper, <br />
                        <span class="text-[var(--accent)] italic"
                            >{paperName}</span
                        >
                    </h1>
                    <p class="mt-4 text-xs md:text-sm text-[var(--muted)]">
                        Download the official {paperName} past paper for {
                            realSubjectName
                        } under the {apiBoardName} examination board.
                    </p>
                </div>
            </div>
        </div>

        <!-- content + sidebar side by side -->
        <div class="grid grid-cols-1 md:grid-cols-[1fr_420px] flex-1">
            <!-- content -->
            <div class="bg-[var(--baby-powder)] px-5 md:px-20 py-8">
                <!-- Viewer -->
                <!-- @ts-ignore -->
                <PaperViewerClient
                    client:only="react"
                    name={paperName}
                    board={boardParam}
                    subject={realSubjectName}
                    year={year}
                    component={component}
                    session={session}
                    type={type}
                    insert={insert}
                    semester={semester}
                />

                <!-- Related papers -->
                <section class="mt-12">
                    <h2 class="font-semibold text-[var(--blue-highlight)]">
                        Related {realSubjectName} Papers
                    </h2>

                    <p class="text-sm opacity-80">
                        Explore more past exam papers from the same subject and
                        year to strengthen your preparation and practice
                        additional exam questions.
                    </p>

                    <ul class="list-disc pl-5 space-y-2 text-sm">
                        {
                            subjectData?.years?.[year]
                                ?.filter((q: any) => q !== question)
                                .slice(0, 10)
                                .map((q: string) => (
                                    <li>
                                        <a
                                            href={`/subjects/${board}/${subject}/${year}/${q}`}
                                            class="hover:underline"
                                        >
                                            {q.replace(/-/g, " ")}
                                        </a>
                                    </li>
                                ))
                        }
                    </ul>
                </section>

                <!-- Navigation links -->
                <section class="text-sm mt-4">
                    <h2 class="font-semibold text-[var(--blue-highlight)]">
                        Browse More Past Papers
                    </h2>

                    <div class="flex flex-wrap gap-4">
                        <a
                            href={`/subjects/${board}/${subject}`}
                            class="hover:underline"
                        >
                            All {realSubjectName} Papers
                        </a>

                        <a href={`/subjects/${board}`} class="hover:underline">
                            All {apiBoardName} Subjects
                        </a>

                        <a href="/pastpapers" class="hover:underline">
                            Browse All Past Papers
                        </a>
                    </div>
                </section>

                <!-- SEO content -->
                <section
                    class="mt-4 text-sm leading-relaxed space-y-4 opacity-80"
                >
                    <h2 class="font-semibold text-[var(--blue-highlight)]">
                        {realSubjectName}
                        {year} Past Paper – {apiBoardName}
                    </h2>

                    <p>
                        This page provides the official <strong
                            >{paperName}</strong
                        > examination paper for <strong
                            >{realSubjectName}</strong
                        > under the <strong>{apiBoardName}</strong>
                        examination board. Students can view and download the full
                        exam paper directly in the browser using the built-in paper
                        viewer.
                    </p>

                    <p>
                        Past papers are one of the most effective study tools
                        for exam preparation. By practicing previous examination
                        papers, students become familiar with the exam
                        structure, marking style, and question difficulty.
                        Regular practice also improves time management and exam
                        confidence.
                    </p>

                    <p>
                        The <strong>{paperName}</strong> paper belongs to the <strong
                            >{year}</strong
                        >
                        examination series for <strong>{realSubjectName}</strong
                        >. Students preparing for exams often practice multiple
                        years of past papers to understand trends in questions
                        and commonly tested topics.
                    </p>

                    <p>
                        You can explore more <strong
                            >{realSubjectName} past papers</strong
                        >, different examination sessions, and other subjects
                        from the
                        <strong>{apiBoardName}</strong> board using the navigation
                        links above. Paper-Guides hosts a large archive of past exam
                        papers to help students revise effectively and prepare for
                        upcoming examinations.
                    </p>

                    <p>
                        <i class="ph-fill ph-question mr-1"></i> Want to practise
                        <strong>{realSubjectName}</strong> questions by topic? Work
                        through past-paper questions filtered by topic at your own
                        pace.
                        <a
                            href={`/questions/${board}/${subject}`}
                            class="text-[var(--accent)] hover:underline"
                            >Browse {realSubjectName} questions →</a
                        >
                    </p>

                    <p>
                        <i class="ph-fill ph-notebook mr-1"></i> Looking for <strong
                            >{realSubjectName}</strong
                        > revision notes? Concise, student-made notes to go alongside
                        your past paper practice.
                        <a
                            href={`/notes/${board}/${subject}`}
                            class="text-[var(--accent)] hover:underline"
                            >Browse {realSubjectName} notes →</a
                        >
                    </p>
                </section>
            </div>

            <!-- ad sidebar: sticky on desktop -->
            <aside
                class="hidden md:flex flex-col items-center gap-4 sticky top-[64px] self-start h-[calc(100vh-64px)] bg-[var(--nav-bg)] border-l border-[var(--border-subtle)] p-6"
            >
                <span class="text-sm text-[var(--muted)]">Sponsor Space</span>
            </aside>
        </div>
    </div>

    <!-- mobile ad strip -->
    <div
        class="md:hidden w-full bg-[var(--nav-bg)] border-t border-[var(--border-subtle)] px-5 py-3 flex items-center justify-center"
    >
        <span class="text-sm text-[var(--muted)]">Sponsor Space</span>
    </div>
</BaseLayout>
