---
export async function getStaticPaths() {
    const index = await getPaperIndex();
    const paths: {
        params: {
            board: string;
            subject: string;
            year: string;
            question: string;
        };
        props: { qpPath: string; msPath: string };
    }[] = [];

    for (const board of Object.keys(index)) {
        for (const subject of Object.keys(index[board])) {
            const years = index[board][subject].years ?? {};
            for (const year of Object.keys(years)) {
                for (const paper of years[year]) {
                    const slug = typeof paper === "string" ? paper : paper.slug;
                    const qpPath =
                        typeof paper === "string" ? "" : (paper.qp_path ?? "");
                    const msPath =
                        typeof paper === "string" ? "" : (paper.ms_path ?? "");
                    paths.push({
                        params: { board, subject, year, question: slug },
                        props: { qpPath, msPath },
                    });
                }
            }
        }
    }

    return paths;
}

import BaseLayout from "../../../../../layouts/BaseLayout.astro";
import { getPaperIndex } from "../../../../../utils/paperIndex";
import { API_URL } from "../../../../../utils/config";

const { board, subject, year, question } = Astro.params;
const { qpPath, msPath } = Astro.props;

const index = await getPaperIndex();
const subjectData = index?.[board]?.[subject];
const realSubjectName = subjectData?.name ?? subject.replace(/-/g, " ");

const boardDisplayName =
    board === "a-levels"
        ? "A Levels"
        : board === "kathmandu-university"
          ? "Kathmandu University"
          : board;

const apiBoardName =
    board === "a-levels"
        ? "A Levels"
        : board === "kathmandu-university"
          ? "Kathmandu University"
          : board;

const paperName = question.replace(/-/g, " ");

const qpUrl = qpPath ? `${API_URL}/papers/${qpPath}` : null;
const msUrl = msPath ? `${API_URL}/papers/${msPath}` : null;

const hasQP = !!qpUrl;
const hasMS = !!msUrl;
---

<BaseLayout
    title={`${realSubjectName} ${year} ${paperName} Past Paper (${boardDisplayName}) | QP & MS`}
    description={`Download the official ${realSubjectName} ${year} ${paperName} past paper for ${apiBoardName}. Includes question papers (QP) and mark schemes (MS) to help students practise real exam questions and improve revision and exam performance.`}
>
    <div class="mt-[64px] min-h-[calc(100vh-64px)] flex flex-col">
        <div class="bg-[#242424] text-[#f7f7f7]">
            <div
                class="py-8 md:py-12 md:px-20 px-5 grid grid-cols-1 md:grid-cols-2 gap-12 items-center"
            >
                <div class="flex flex-col justify-center">
                    <span
                        class="text-[var(--muted)] text-xs flex items-center gap-1 flex-wrap mb-4"
                    >
                        <a href="/"><i class="ph-fill ph-house"></i> Home</a> /
                        <a href="/pastpapers"
                            ><i class="ph-fill ph-exam"></i> Past Papers</a
                        > /
                        <a href={`/subjects/${board}`}
                            ><i class="ph-fill ph-book"></i> {boardDisplayName}</a
                        > /
                        <a href={`/subjects/${board}/${subject}`}
                            ><i class="ph-fill ph-books"></i> {realSubjectName}</a
                        > /
                        <a href={`/subjects/${board}/${subject}/${year}`}
                            ><i class="ph-fill ph-file"></i> {year}</a
                        > /
                        <span
                            ><i class="ph-fill ph-file-text"></i> {paperName}</span
                        >
                    </span>

                    <h1 class="font-serif font-bold text-2xl md:text-4xl">
                        {realSubjectName}
                        {year}
                        <br />
                        <span class="text-[var(--accent)] italic">
                            {paperName} Past Paper ({boardDisplayName})
                        </span>
                    </h1>
                    <p class="mt-4 text-xs md:text-sm text-[var(--muted)]">
                        Download the official {realSubjectName}
                        {year}
                        {paperName} past paper for the {apiBoardName} examination
                        board. Includes authentic exam questions from previous sessions
                        to support structured revision and exam preparation.
                    </p>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-[1fr_420px] flex-1">
            <div class="bg-[var(--baby-powder)] px-5 md:px-20 py-8">

                {
                    !hasQP && !hasMS ? (
                        <div class="flex items-center justify-center h-64 opacity-50">
                            Paper not available
                        </div>
                    ) : (
                        <div>
                            <!-- Controls bar -->
                            <div class="flex flex-wrap items-center justify-between gap-3 mb-5">
                                <!-- Toggle QP / MS -->
                                <div class="flex gap-2">
                                    {hasQP && (
                                        <button
                                            id="btn-qp"
                                            class="text-sm font-bold px-4 py-2 rounded-lg transition flex items-center gap-2 bg-[var(--blue-highlight)] text-white"
                                        >
                                            <i class="ph ph-file-text" /> Question Paper
                                        </button>
                                    )}
                                    {hasMS && (
                                        <button
                                            id="btn-ms"
                                            class="text-sm font-bold px-4 py-2 rounded-lg transition flex items-center gap-2 bg-[var(--color-surface)] text-[var(--muted)] border border-[var(--border-subtle)]"
                                        >
                                            <i class="ph ph-check-circle" /> Mark Scheme
                                        </button>
                                    )}
                                </div>

                                <!-- Open / Download -->
                                <div class="flex gap-2">
                                    <a
                                        id="btn-open"
                                        href={qpUrl ?? msUrl ?? "#"}
                                        target="_blank"
                                        class="text-sm font-bold px-4 py-2 rounded-lg hover:opacity-80 transition flex items-center gap-2 bg-[var(--blue-highlight)] text-white"
                                    >
                                        <i class="ph ph-arrow-square-out" /> Open Full-Screen
                                    </a>
                                    <a
                                        id="btn-download"
                                        href={qpUrl ?? msUrl ?? "#"}
                                        download
                                        class="text-sm font-bold px-4 py-2 rounded-lg hover:opacity-80 transition flex items-center gap-2 bg-[var(--green-highlight)] text-white"
                                    >
                                        <i class="ph ph-download" /> Download
                                    </a>
                                </div>
                            </div>

                            <!-- Label above viewer -->
                            <p id="viewer-label" class="text-xs uppercase tracking-widest text-[var(--muted)] font-semibold mb-3">
                                Question Paper
                            </p>

                            <!-- PDF viewer -->
                            <object
                                id="pdf-viewer"
                                data={qpUrl ?? msUrl ?? ""}
                                type="application/pdf"
                                class="w-full h-screen border rounded shadow"
                            >
                                <p class="text-center mt-8 opacity-60">
                                    Your browser can't display PDFs inline.
                                    <a
                                        id="fallback-download"
                                        href={qpUrl ?? msUrl ?? "#"}
                                        download
                                        class="text-[var(--accent)] hover:underline ml-1"
                                    >
                                        Download instead
                                    </a>
                                </p>
                            </object>
                        </div>
                    )
                }

                <!-- Related papers -->
                <section class="mt-12">
                    <h2 class="font-semibold text-[var(--blue-highlight)]">
                        More {realSubjectName}
                        {year} Past Papers ({boardDisplayName})
                    </h2>
                    <p class="text-sm opacity-80 mb-3">
                        Explore more past exam papers from the same subject and
                        year to strengthen your preparation.
                    </p>
                    <ul class="list-disc pl-5 space-y-2 text-sm">
                        {
                            subjectData?.years?.[year]
                                ?.filter((p: any) => {
                                    const s =
                                        typeof p === "string" ? p : p.slug;
                                    return s !== question;
                                })
                                .slice(0, 10)
                                .map((p: any) => {
                                    const s =
                                        typeof p === "string" ? p : p.slug;
                                    return (
                                        <li>
                                            <a
                                                href={`/subjects/${board}/${subject}/${year}/${s}`}
                                                class="hover:underline"
                                            >
                                                {s.replace(/-/g, " ")}
                                            </a>
                                        </li>
                                    );
                                })
                        }
                    </ul>
                </section>

                <!-- Navigation links -->
                <section class="text-sm mt-4">
                    <h2 class="font-semibold text-[var(--blue-highlight)]">
                        Browse More Past Papers
                    </h2>
                    <div class="flex flex-wrap gap-4">
                        <a
                            href={`/subjects/${board}/${subject}`}
                            class="hover:underline"
                        >
                            All {realSubjectName} Papers
                        </a>
                        <a href={`/subjects/${board}`} class="hover:underline">
                            All {apiBoardName} Subjects
                        </a>
                        <a href="/pastpapers" class="hover:underline">
                            Browse All Past Papers
                        </a>
                    </div>
                </section>

                <!-- SEO content -->
                <section class="mt-4 text-sm leading-relaxed space-y-4 opacity-80">
                    <h2 class="font-semibold text-[var(--blue-highlight)]">
                        {realSubjectName}
                        {year} Past Paper – {apiBoardName}
                    </h2>
                    <p>
                        This page provides the official <strong>{paperName}</strong>
                        examination paper for <strong>{realSubjectName}</strong> under
                        the <strong>{apiBoardName}</strong> examination board. Students
                        can view and download the full exam paper directly in the browser.
                    </p>
                    <p>
                        Past papers are one of the most effective study tools for exam
                        preparation. By practising previous papers, students become
                        familiar with the exam structure, marking style, and question
                        difficulty.
                    </p>
                    <p>
                        <i class="ph-fill ph-question mr-1"></i> Want to practise{" "}
                        <strong>{realSubjectName}</strong> questions by topic?
                        <a
                            href={`/questions/${board}/${subject}`}
                            class="text-[var(--accent)] hover:underline"
                        >
                            Browse {realSubjectName} questions →
                        </a>
                    </p>
                    <p>
                        <i class="ph-fill ph-notebook mr-1"></i> Looking for{" "}
                        <strong>{realSubjectName}</strong> revision notes?
                        <a
                            href={`/notes/${board}/${subject}`}
                            class="text-[var(--accent)] hover:underline"
                        >
                            Browse {realSubjectName} notes →
                        </a>
                    </p>
                </section>
            </div>

            <aside
                class="hidden md:flex flex-col items-center gap-4 sticky top-[64px] self-start h-[calc(100vh-64px)] bg-[var(--nav-bg)] border-l border-[var(--border-subtle)] p-6"
            >
                <span class="text-sm text-[var(--muted)]">Sponsor Space</span>
            </aside>
        </div>
    </div>

    <section class="sr-only">
        <h2>
            {realSubjectName}
            {year}
            {paperName} Past Paper
        </h2>
        <p>
            This page hosts the official {realSubjectName}
            {year}
            {paperName} past examination paper under the {apiBoardName} curriculum.
            Students can view and download the complete exam paper and mark scheme
            to support structured revision and exam preparation.
        </p>
    </section>

    <div
        class="md:hidden w-full bg-[var(--nav-bg)] border-t border-[var(--border-subtle)] px-5 py-3 flex items-center justify-center"
    >
        <span class="text-sm text-[var(--muted)]">Sponsor Space</span>
    </div>

    <script define:vars={{ qpUrl, msUrl, hasQP, hasMS }}>
        const viewer = document.getElementById("pdf-viewer");
        const label = document.getElementById("viewer-label");
        const btnOpen = document.getElementById("btn-open");
        const btnDownload = document.getElementById("btn-download");
        const fallback = document.getElementById("fallback-download");
        const btnQP = document.getElementById("btn-qp");
        const btnMS = document.getElementById("btn-ms");

        const ACTIVE =
            "bg-[var(--blue-highlight)] text-white";
        const INACTIVE =
            "bg-[var(--color-surface)] text-[var(--muted)] border border-[var(--border-subtle)]";

        let current = hasQP ? "qp" : "ms";

        function switchTo(mode) {
            current = mode;
            const url = mode === "qp" ? qpUrl : msUrl;

            if (viewer) viewer.setAttribute("data", url);
            if (label) label.textContent = mode === "qp" ? "Question Paper" : "Mark Scheme";
            if (btnOpen) btnOpen.setAttribute("href", url);
            if (btnDownload) btnDownload.setAttribute("href", url);
            if (fallback) fallback.setAttribute("href", url);

            if (btnQP) {
                btnQP.className = btnQP.className
                    .replace(ACTIVE, "").replace(INACTIVE, "").trim();
                btnQP.className += " " + (mode === "qp" ? ACTIVE : INACTIVE);
            }
            if (btnMS) {
                btnMS.className = btnMS.className
                    .replace(ACTIVE, "").replace(INACTIVE, "").trim();
                btnMS.className += " " + (mode === "ms" ? ACTIVE : INACTIVE);
            }
        }

        if (btnQP) btnQP.addEventListener("click", () => switchTo("qp"));
        if (btnMS) btnMS.addEventListener("click", () => switchTo("ms"));
    </script>
</BaseLayout>
