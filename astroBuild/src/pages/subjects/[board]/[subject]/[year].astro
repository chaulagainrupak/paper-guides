---
export const prerender = false;

import { getPaperIndex } from "../../../../utils/paperIndex";
import BaseLayout from "../../../../layouts/BaseLayout.astro";

const { board, subject, year } = Astro.params;

const index = await getPaperIndex();

let slugs: string[] = [];

try {
  slugs = index?.[board!]?.[subject!]?.years?.[year!] ?? [];
} catch (err) {
  console.error("Failed to fetch papers:", err);
}

const realSubjectName =
  index?.[board!]?.[subject!]?.name ?? subject!.replace(/-/g, " ");

const boardDisplayName =
  board === "a-levels"
    ? "A Levels"
    : board === "kathmandu-university"
      ? "Kathmandu University"
      : board;

// Month mapping for session display
const monthMap: Record<string, string> = {
  "01": "January",
  "02": "February",
  "03": "March",
  "04": "April",
  "05": "May",
  "06": "June",
  "07": "July",
  "08": "August",
  "09": "September",
  "10": "October",
  "11": "November",
  "12": "December",
};

const getSessionDisplay = (slug: string): string => {
  const parts = slug.split("-");
  const lastPart = parts[parts.length - 1]; // year
  const secondLast = parts[parts.length - 2]; // month/session info

  // Convert month numbers to month names
  let sessionName = secondLast;
  if (monthMap[secondLast]) {
    sessionName = monthMap[secondLast];
  } else {
    // Handle cases like "may-june" by capitalizing each word
    sessionName = secondLast
      .split("-")
      .map(
        (word) =>
          monthMap[word] || word.charAt(0).toUpperCase() + word.slice(1),
      )
      .join("-");
  }

  return `${sessionName} ${lastPart}`;
};

const getPaperDisplay = (
  slug: string,
  board: string,
  realSubjectName: string,
  year: string,
): string => {
  if (board === "kathmandu-university") {
    const semesterMatch = slug.match(/semester-\d+/i);
    const semester = semesterMatch
      ? semesterMatch[0]
          .replace("-", " ")
          .replace(/\b\w/g, (l) => l.toUpperCase())
      : "";
    return `${realSubjectName}, ${semester}, ${year}`;
  } else {
    const insert = slug.includes("insert-paper");
    const clean = slug.replace("-insert-paper", "");
    const type = clean.includes("mark-scheme") ? "MS" : "QP";
    const parts = clean.split("-");
    const component = parts[parts.length - 4];
    return `${realSubjectName}, ${component} ${type}, ${year}`;
  }
};

// Group slugs by session
const sessions = new Map<string, string[]>();
for (const slug of slugs) {
  const session = getSessionDisplay(slug);
  if (!sessions.has(session)) sessions.set(session, []);
  sessions.get(session)!.push(slug);
}

// Sort sessions alphabetically (latest first if years are included)
const sortedSessions = Array.from(sessions.entries()).sort(([a], [b]) =>
  b.localeCompare(a),
);

