---
export const prerender = false;

import LevelTopicalsLayout from "../../../../layouts/LevelTopicalsLayout.astro";
import BackButton from "../../../../components/BackButton.astro";
import { getPaperIndex } from "../../../../utils/paperIndex";

const { board, subject, year } = Astro.params;

const index = await getPaperIndex();

let slugs: string[] = [];

try {
  slugs = index?.[board!]?.[subject!]?.years?.[year!] ?? [];
} catch (err) {
  console.error("Failed to fetch papers:", err);
}

// export const getStaticPaths = async () => {
//   const index = await getPaperIndex();

//   const paths = [];

//   for (const board in index) {
//     for (const subject in index[board]) {
//       const years = index[board][subject].years;

//       for (const year in years) {
//         paths.push({
//           params: { board, subject, year },
//         });
//       }
//     }
//   }

//   return paths;
// };

const realSubjectName =
  index?.[board!]?.[subject!]?.name ?? subject!.replace(/-/g, " ");

const grouped: Record<string, string[]> = {};

for (const slug of slugs) {
  const parts = slug.split("-");
  const session = `${parts[parts.length - 2]}-${parts[parts.length - 1]}`;

  if (!grouped[session]) grouped[session] = [];
  grouped[session].push(slug);
}
---

<LevelTopicalsLayout
  title={`Available papers for ${realSubjectName} — ${year} | Paper Guides`}
  description={`Explore the available papers for ${realSubjectName} in ${year}.`}
>
  <div class="flex justify-between items-center border-b-2 border-[var(--blue-highlight)] pb-4 mb-4">
    <h1 class="text-4xl font-bold">
      Available <span class="text-[var(--blue-highlight)]">Papers</span> for
      <span class="text-[var(--blue-highlight)]"> {realSubjectName}</span>
    </h1>
    <BackButton />
  </div>

  {Object.entries(grouped).map(([session, papers]) => (
    <div>
      <h2 class="text-3xl font-bold mt-6 underline">• {session}</h2>

      <div class="space-y-4 mt-2">
        {papers.map((slug) => (
          <a
            href={`/subjects/${board}/${subject}/${year}/${slug}`}
            class="border border-[var(--blue-highlight)] block p-4 rounded-xl text-xl font-bold bg-[var(--color-nav)] text-[var(--font-color)] shadow-xl hover:scale-[1.01] transition"
          >
            {slug.replace(/-/g, " ")}
          </a>
        ))}
      </div>
    </div>
  ))}

  {slugs.length === 0 && (
    <p class="opacity-60 mt-6">No papers found for this year.</p>
  )}
</LevelTopicalsLayout>