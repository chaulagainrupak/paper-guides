---
import { getPaperIndex } from "../../../../utils/paperIndex";
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import FeaturedSlot from "../../../../components/Campaign";

export const prerender = true;

export async function getStaticPaths() {
    const index = await getPaperIndex();
    const paths = [];

    for (const [board, boardData] of Object.entries(index)) {
        for (const [subject, subjectData] of Object.entries(boardData)) {
            const years = subjectData.years ?? {};
            for (const year of Object.keys(years)) {
                paths.push({
                    params: { board, subject, year },
                });
            }
        }
    }

    return paths;
}

const { board, subject, year } = Astro.params;

const index = await getPaperIndex();

let rawPapers = [];

try {
    rawPapers = index?.[board]?.[subject]?.years?.[year] ?? [];
} catch (err) {
    console.error("Failed to fetch papers:", err);
}

const slugsSet = new Set();
for (const p of rawPapers) {
    const slug = typeof p === "string" ? p : p.slug;
    if (slug) slugsSet.add(slug);
}
const slugs = Array.from(slugsSet);

const realSubjectName =
    index?.[board]?.[subject]?.name ?? subject.replace(/-/g, " ");

const boardDisplayName =
    board === "a-levels"
        ? "A Levels"
        : board === "kathmandu-university"
          ? "Kathmandu University"
          : board;

const SESSION_ORDER = { mj: 1, on: 2, fj: 3, fm: 3 };

const SESSION_LABELS = {
    mj: "May/June",
    on: "Oct/Nov",
    fj: "Feb/Mar",
    fm: "Feb/Mar",
};

function getSessionCode(slug) {
    const lower = slug.toLowerCase();
    if (lower.includes("oct-nov") || lower.includes("october-november"))
        return "on";
    if (lower.includes("may-jun") || lower.includes("may-june")) return "mj";
    if (lower.includes("feb-mar") || lower.includes("february-march"))
        return "fj";
    for (const code of Object.keys(SESSION_LABELS)) {
        if (lower.includes(`-${code}-`) || lower.startsWith(`${code}-`))
            return code;
    }
    const semMatch = lower.match(/semester-(\d+)/);
    if (semMatch) return `semester-${semMatch[1]}`;
    return "other";
}

function getSessionLabel(code) {
    if (SESSION_LABELS[code]) return SESSION_LABELS[code];
    if (code.startsWith("semester-")) return `Semester ${code.split("-")[1]}`;
    return code.toUpperCase();
}

function getComponent(slug) {
    const match = slug.match(/-(\d{2})(?:-qp|-ms|$)/);
    return match ? parseInt(match[1], 10) : 999;
}

function getPaperNumber(component) {
    return Math.floor(component / 10);
}

function getType(slug) {
    if (slug.includes("insert-paper")) return "insert";
    if (slug.includes("-ms")) return "ms";
    return "qp";
}

function sortSlugs(slugs) {
    return slugs.sort((a, b) => {
        const compA = getComponent(a);
        const compB = getComponent(b);
        if (compA !== compB) return compA - compB;
        const typeOrder = { qp: 0, insert: 1, ms: 2 };
        return typeOrder[getType(a)] - typeOrder[getType(b)];
    });
}

const sessions = new Map();
for (const slug of slugs) {
    const code = getSessionCode(slug);
    if (!sessions.has(code)) sessions.set(code, []);
    sessions.get(code).push(slug);
}

const sortedSessions = Array.from(sessions.entries()).sort(([a], [b]) => {
    const aOrder = SESSION_ORDER[a] ?? 99;
    const bOrder = SESSION_ORDER[b] ?? 99;
    return aOrder - bOrder || a.localeCompare(b);
});
---

<BaseLayout
    title={`${realSubjectName} ${year} Past Papers (${boardDisplayName})`}
    description={`Access ${realSubjectName} ${year} past papers for ${boardDisplayName}`}
>
    <div class="mt-[64px] min-h-[calc(100vh-64px)] flex flex-col">
        <div
            class="bg-[#242424] text-[#f7f7f7] py-12 md:py-20 md:px-20 px-5 grid grid-cols-1 md:grid-cols-2 gap-12 items-center"
        >
            <div class="flex flex-col justify-center">
                <span
                    class="text-[var(--muted)] mb-6 text-xs flex items-center gap-1 flex-wrap"
                >
                    <a href="/"><i class="ph-fill ph-house"></i> Home</a> /
                    <a href="/pastpapers"
                        ><i class="ph-fill ph-exam"></i> Past Papers</a
                    > /
                    <a href={`/subjects/${board}`}
                        ><i class="ph-fill ph-book"></i> {boardDisplayName}</a
                    > /
                    <a href={`/subjects/${board}/${subject}`}
                        ><i class="ph-fill ph-books"></i> {realSubjectName}</a
                    > /
                    <span><i class="ph-fill ph-calendar"></i> {year}</span>
                </span>

                <h1 class="font-serif font-bold text-4xl md:text-6xl">
                    {realSubjectName}
                    {year}
                    <br />
                    <span class="text-[var(--accent)] italic">
                        Past Papers ({boardDisplayName})
                    </span>
                </h1>

                <p class="mt-4 text-xs md:text-sm text-[var(--muted)]">
                    Browse all available sessions and papers for {
                        realSubjectName
                    }
                    {year} under the {boardDisplayName} curriculum.
                    {
                        slugs.length > 0
                            ? ` Currently listing ${slugs.length} paper${slugs.length > 1 ? "s" : ""} across ${sortedSessions.length} session${sortedSessions.length > 1 ? "s" : ""}.`
                            : " No papers found for this year."
                    }
                </p>
            </div>

            <div class="flex flex-col justify-end h-full gap-3">
                <span
                    class="text-xs text-[var(--muted)] uppercase tracking-widest"
                    >Search papers</span
                >
                <input
                    id="paper-search"
                    type="text"
                    placeholder="e.g. Paper 12 QP…"
                    class="w-full bg-transparent border-b border-[var(--muted)] text-[#f7f7f7] placeholder:text-[var(--muted)] focus:outline-none focus:border-[var(--accent)] py-2 text-lg transition-colors duration-200"
                />
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-[1fr_360px] flex-1">
            <div id="paper-list" class="bg-[var(--baby-powder)] flex flex-col">
                <!-- Refined jump navigation – clean, subtle, sticky -->
                <div
                    class="sticky top-[64px] z-10 bg-white/95 backdrop-blur-sm px-5 md:px-8 lg:px-20 py-3 border-b border-[var(--border-subtle)] shadow-sm flex items-center gap-4 flex-wrap"
                >
                    <span
                        class="text-xs font-semibold uppercase tracking-wider text-[var(--muted)] flex items-center gap-2"
                    >
                        <i class="ph-fill ph-compass text-[var(--accent)]"></i> Jump
                        to
                    </span>
                    <div class="flex flex-wrap gap-2">
                        {
                            sortedSessions.map(([code]) => (
                                <a
                                    href={`#session-${code}`}
                                    class="text-sm font-medium px-3 py-1.5 rounded-full bg-[var(--accent)]/10 text-[var(--accent)] hover:bg-[var(--accent)] hover:text-white transition-colors duration-200 border border-transparent hover:border-[var(--accent)]"
                                >
                                    {getSessionLabel(code)}
                                </a>
                            ))
                        }
                    </div>
                </div>

                {
                    sortedSessions.map(([code, sessionSlugs]) => {
                        const sorted = sortSlugs(sessionSlugs);

                        const groups = new Map();
                        for (const slug of sorted) {
                            const comp = getComponent(slug);
                            const paperNum = getPaperNumber(comp);
                            if (!groups.has(paperNum)) groups.set(paperNum, []);
                            groups.get(paperNum).push(slug);
                        }

                        const sortedGroups = Array.from(groups.entries()).sort(
                            ([a], [b]) => a - b,
                        );

                        return (
                            <div
                                id={`session-${code}`}
                                class="scroll-mt-[64px]"
                            >
                                <div class="bg-[var(--color-surface)] border-b border-[var(--border-subtle)] px-5 md:px-8 lg:px-20 py-3">
                                    <h2 class="text-xs uppercase tracking-widest text-[var(--muted)]">
                                        {getSessionLabel(code)} {year}
                                    </h2>
                                </div>

                                {sortedGroups.map(([paperNum, groupSlugs]) => (
                                    <div>
                                        <div class="bg-[rgba(0,0,0,0.03)] border-b border-[var(--border-subtle)] px-5 md:px-20 py-2">
                                            <h3 class="text-xs uppercase tracking-wider text-[var(--muted)]">
                                                Paper {paperNum}
                                            </h3>
                                        </div>

                                        {groupSlugs.map((slug) => {
                                            const component =
                                                getComponent(slug);
                                            const type = getType(slug);
                                            const typeLabel =
                                                type === "qp"
                                                    ? "QP"
                                                    : type === "ms"
                                                      ? "MS"
                                                      : "Insert";

                                            const searchData =
                                                `${realSubjectName} ${component} ${typeLabel} ${year} ${getSessionLabel(code)} paper`.toLowerCase();

                                            return (
                                                <a
                                                    data-name={searchData}
                                                    href={`/subjects/${board}/${subject}/${year}/${slug}`}
                                                    class="group relative border-b border-[var(--border-subtle)] px-5 md:px-8 lg:px-20 py-6 text-[var(--font-color)] transition-all duration-300 ease-out
                                                       bg-[var(--baby-powder)] hover:bg-gradient-to-r hover:from-[var(--baby-powder)] hover:to-[rgba(74,222,128,0.05)]
                                                       hover:shadow-lg hover:scale-[1.02] hover:translate-y-[-4px]
                                                       flex items-center justify-between"
                                                >
                                                    <div class="flex items-center gap-3">
                                                        <span class="font-bold text-lg group-hover:text-[var(--accent)] transition-colors">
                                                            {realSubjectName}{" "}
                                                            {component}
                                                        </span>
                                                        <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-[var(--accent)]/10 text-[var(--accent)]">
                                                            {typeLabel}
                                                        </span>
                                                    </div>

                                                    <div class="flex items-center gap-3">
                                                        <span class="text-xs font-semibold text-[var(--accent)] opacity-0 group-hover:opacity-100 transition-opacity duration-300 whitespace-nowrap">
                                                            View
                                                        </span>
                                                        <i class="ph-fill ph-arrow-right text-[var(--muted)] text-2xl md:text-3xl shrink-0 transition-all duration-300 group-hover:translate-x-2 group-hover:text-[var(--accent)]" />
                                                    </div>
                                                </a>
                                            );
                                        })}
                                    </div>
                                ))}
                            </div>
                        );
                    })
                }

                <div
                    id="no-results"
                    class="hidden flex-col items-center justify-center py-24 gap-4 text-[var(--muted)]"
                >
                    <i
                        class="ph-fill ph-smiley-x-eyes text-6xl text-[var(--jungle-green)]"
                    ></i>
                    <p class="text-sm">No papers match your search.</p>
                </div>
            </div>

            <aside
                class="hidden lg:flex flex-col items-center gap-4 sticky top-[64px] self-start h-[calc(100vh-64px)] bg-[var(--nav-bg)] border-l border-[var(--border-subtle)] p-6"
            >
                <FeaturedSlot client:only="react" />
            </aside>
        </div>

        <div
            class="lg:hidden w-full bg-[var(--nav-bg)] border-t border-[var(--border-subtle)] px-5 py-4 flex items-center justify-center"
        >
            <FeaturedSlot variant="horizontal" client:only="react" />
        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const input = document.getElementById("paper-search");
            const items = Array.from(
                document.querySelectorAll("#paper-list a[data-name]"),
            );
            const noResults = document.getElementById("no-results");

            function filter(q) {
                q = q.toLowerCase().trim();
                let anyVisible = false;

                items.forEach((el) => {
                    const data = el.dataset.name || "";
                    const ok = data.includes(q);
                    el.style.display = ok ? "" : "none";
                    if (ok) anyVisible = true;
                });

                noResults.classList.toggle("hidden", anyVisible);
            }

            input.addEventListener("input", (e) => filter(e.target.value));
        });
    </script>
</BaseLayout>
