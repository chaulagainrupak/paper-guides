---
// export const prerender = false;

import FeaturedSlot from "../../components/Campaign";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPaperIndex } from "../../utils/paperIndex";

type Params = { board: string };
const { board } = Astro.params as Params;

let subjects: { name: string; slug: string }[] = [];
let globalIndex: any;

try {
    const index = await getPaperIndex();
    globalIndex = index;
    subjects = Object.keys(index?.[board] ?? {})
        .map((s) => ({
            slug: s,
            name: index[board][s]["name"],
        }))
        .sort((a, b) =>
            a.name.localeCompare(b.name, undefined, { sensitivity: "base" }),
        );
} catch (err) {
    console.error("Failed to fetch subjects:", err);
}

const boardDisplayName =
    board === "a-levels"
        ? "A Levels"
        : board === "kathmandu-university"
          ? "Kathmandu University"
          : board;

export async function getStaticPaths() {
    const index = await getPaperIndex();

    const paths: { params: { board: string } }[] = [];

    for (const board of Object.keys(index)) {
        paths.push({ params: { board } });
    }

    return paths;
}

// Chunk subjects into 4 equal-ish sections for inline ad breaks
// Only bother if list is long enough to warrant it (> 40 items)
const CHUNK_SIZE = Math.ceil(subjects.length / 4);
const USE_CHUNKS = subjects.length > 40;
const chunks: { name: string; slug: string }[][] = [];
if (USE_CHUNKS) {
    for (let i = 0; i < subjects.length; i += CHUNK_SIZE) {
        chunks.push(subjects.slice(i, i + CHUNK_SIZE));
    }
} else {
    chunks.push(subjects);
}
---

<BaseLayout
    title={`Available Past Papers Subjects for ${boardDisplayName} | Paper Guides`}
    description={`Browse the complete list of ${boardDisplayName} past paper subjects on Paper Guides. Find subject-wise past exam papers, organized by year and component, with downloadable questions to help students prepare effectively for ${boardDisplayName} examinations.`}
>
    <div class="mt-[64px] min-h-[calc(100vh-64px)] flex flex-col">
        <!-- header -->
        <div
            class="bg-[#242424] text-[#f7f7f7] py-12 md:py-20 md:px-8 lg:px-20 px-5 grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-center"
        >
            <div class="flex flex-col justify-center">
                <span
                    class="text-[var(--muted)] mb-6 text-xs flex items-center gap-1"
                >
                    <a href="/"><i class="ph-fill ph-house"></i> Home</a> /
                    <a href="/pastpapers"
                        ><i class="ph-fill ph-exam"></i> Past Papers</a
                    > /
                    <a href={`/subjects/${board}`}
                        ><i class="ph-fill ph-book"></i> {boardDisplayName}</a
                    >
                </span>
                <h1 class="font-serif font-bold text-4xl md:text-5xl lg:text-6xl">
                    {boardDisplayName}
                    <br />
                    <span class="text-[var(--accent)] italic">
                        Past Papers Subjects
                    </span>
                </h1>
                <p class="mt-4 text-xs md:text-sm text-[var(--muted)] max-w-lg">
                    Browse all available subjects for {boardDisplayName}. Each
                    subject page includes organized past exam papers sorted by
                    year and component, helping students quickly locate relevant
                    questions for revision and exam practice. Currently listing
                    {subjects.length} subjects under the {boardDisplayName} curriculum.
                </p>
            </div>

            <div class="flex flex-col justify-end h-full gap-3">
                <span
                    class="text-xs text-[var(--muted)] uppercase tracking-widest"
                    >Search subjects</span
                >
                <input
                    type="text"
                    id="subject-search"
                    placeholder="e.g. Mathematics..."
                    class="w-full bg-transparent border-b border-[var(--muted)] text-[#f7f7f7] placeholder:text-[var(--muted)] focus:outline-none focus:border-[var(--accent)] py-2 text-lg transition-colors duration-200"
                />
            </div>
        </div>

        <!-- subject list + sidebar -->
        <!-- sidebar kicks in at lg (1024px) not md — md is too narrow for 420px aside -->
        <div class="grid grid-cols-1 lg:grid-cols-[1fr_360px] flex-1">
            <div
                id="subject-list"
                class="bg-[var(--baby-powder)] flex flex-col"
            >
                <span
                    class="bg-[var(--color-surface)] text-sm text-[var(--muted)] uppercase tracking-widest px-5 md:px-8 lg:px-20 py-3 border-b border-[var(--border-subtle)]"
                >
                    Click a subject to explore past papers for {
                        boardDisplayName
                    }. {USE_CHUNKS && <span class="normal-case not-italic opacity-60">— {subjects.length} subjects, split into sections</span>}
                </span>

                {
                    USE_CHUNKS ? (
                        chunks.map((chunk, chunkIdx) => (
                            <div class="chunk-section" data-chunk={chunkIdx}>
                                {chunk.map(({ name, slug }) => (
                                    <a
                                        data-name={name.toLowerCase()}
                                        href={`/subjects/${board}/${slug}`}
                                        class="group relative border-b border-[var(--border-subtle)] px-5 md:px-8 lg:px-20 py-6 text-[var(--font-color)] transition-all duration-300 ease-out
                               bg-[var(--baby-powder)] hover:bg-gradient-to-r hover:from-[var(--baby-powder)] hover:to-[rgba(74,222,128,0.05)]
                               hover:shadow-lg hover:scale-[1.02] hover:translate-y-[-4px]
                               flex items-center justify-between"
                                    >
                                        <div class="flex gap-3">
                                            <span class="font-bold text-xl group-hover:text-[var(--accent)] transition-colors">
                                                {name}
                                            </span>
                                        </div>

                                        <div class="flex items-center gap-3 ml-4">
                                            <div class="flex items-center gap-2 flex-wrap">
                                                <span class="text-xs px-2 py-1 bg-[var(--accent)]/20 text-[var(--accent)] rounded-full">
                                                    {
                                                        Object.keys(
                                                            globalIndex[board][slug][
                                                                "years"
                                                            ],
                                                        ).length
                                                    }{" "}
                                                    years
                                                </span>
                                                <span class="text-xs px-2 py-1 bg-[var(--blue-highlight)]/20 text-[var(--blue-highlight)] rounded-full">
                                                    {
                                                        // @ts-ignore
                                                        Object.values(
                                                            globalIndex[board][slug][
                                                                "years"
                                                            ],
                                                        ).reduce(
                                                            (acc, arr) => acc + arr.length,
                                                            0,
                                                        )
                                                    }{" "}
                                                    papers
                                                </span>
                                            </div>

                                            <span class="text-xs font-semibold text-[var(--accent)] opacity-0 group-hover:opacity-100 transition-opacity duration-300 whitespace-nowrap">
                                                Explore
                                            </span>
                                            <i class="ph-fill ph-arrow-right text-[var(--muted)] text-2xl md:text-3xl shrink-0 transition-all duration-300 group-hover:translate-x-2 group-hover:text-[var(--accent)]" />
                                        </div>
                                    </a>
                                ))}

                                {/* Ad break between chunks — not after the last one */}
                                {chunkIdx < chunks.length - 1 && (
                                    <div
                                        class="ad-break border-b border-[var(--border-subtle)] px-5 md:px-8 lg:px-20 py-5 bg-[var(--color-surface)]/50 flex items-center gap-5"
                                        data-ad-break
                                    >
                                        <div class="flex-1 h-px bg-[var(--border-subtle)]" />
                                        <div data-ad-mount class="max-w-2xl w-full"></div>
                                        <div class="flex-1 h-px bg-[var(--border-subtle)]" />
                                    </div>
                                )}
                            </div>
                        ))
                    ) : (
                        subjects.map(({ name, slug }) => (
                            <a
                                data-name={name.toLowerCase()}
                                href={`/subjects/${board}/${slug}`}
                                class="group relative border-b border-[var(--border-subtle)] px-5 md:px-8 lg:px-20 py-6 text-[var(--font-color)] transition-all duration-300 ease-out
                       bg-[var(--baby-powder)] hover:bg-gradient-to-r hover:from-[var(--baby-powder)] hover:to-[rgba(74,222,128,0.05)]
                       hover:shadow-lg hover:scale-[1.02] hover:translate-y-[-4px]
                       flex items-center justify-between"
                            >
                                <div class="flex gap-3">
                                    <span class="font-bold text-xl group-hover:text-[var(--accent)] transition-colors">
                                        {name}
                                    </span>
                                </div>

                                <div class="flex items-center gap-3 ml-4">
                                    <div class="flex items-center gap-2 flex-wrap">
                                        <span class="text-xs px-2 py-1 bg-[var(--accent)]/20 text-[var(--accent)] rounded-full">
                                            {
                                                Object.keys(
                                                    globalIndex[board][slug][
                                                        "years"
                                                    ],
                                                ).length
                                            }{" "}
                                            years
                                        </span>
                                        <span class="text-xs px-2 py-1 bg-[var(--blue-highlight)]/20 text-[var(--blue-highlight)] rounded-full">
                                            {
                                                // @ts-ignore
                                                Object.values(
                                                    globalIndex[board][slug][
                                                        "years"
                                                    ],
                                                ).reduce(
                                                    (acc, arr) => acc + arr.length,
                                                    0,
                                                )
                                            }{" "}
                                            papers
                                        </span>
                                    </div>

                                    <span class="text-xs font-semibold text-[var(--accent)] opacity-0 group-hover:opacity-100 transition-opacity duration-300 whitespace-nowrap">
                                        Explore
                                    </span>
                                    <i class="ph-fill ph-arrow-right text-[var(--muted)] text-2xl md:text-3xl shrink-0 transition-all duration-300 group-hover:translate-x-2 group-hover:text-[var(--accent)]" />
                                </div>
                            </a>
                        ))
                    )
                }

                <div
                    id="no-results"
                    class="hidden flex-col items-center justify-center py-24 gap-4 text-[var(--muted)]"
                >
                    <i
                        class="ph-fill ph-smiley-x-eyes text-6xl text-[var(--jungle-green)]"
                    ></i>
                    <p class="text-sm">No subjects match your search.</p>
                </div>
            </div>

            <!-- sidebar only at lg+, narrowed to 360px so content has room -->
            <aside
                class="hidden lg:flex flex-col items-center gap-4 sticky top-[64px] self-start h-[calc(100vh-64px)] bg-[var(--nav-bg)] border-l border-[var(--border-subtle)] p-6"
            >
                <FeaturedSlot client:only="react" />
            </aside>
        </div>
    </div>

    <!-- mobile + md strip (below lg) -->
    <div
        class="lg:hidden w-full bg-[var(--nav-bg)] border-t border-[var(--border-subtle)] px-5 py-4 flex items-center justify-center"
    >
        <FeaturedSlot variant="horizontal" client:only="react" />
    </div>

    <script>
        import { fuzzyFilter } from "../../utils/search";

        const input = document.getElementById(
            "subject-search",
        ) as HTMLInputElement;
        // get all subject links (skip ad-break divs)
        const items = Array.from(
            document.querySelectorAll("#subject-list a[data-name]"),
        ) as HTMLElement[];
        const adBreaks = Array.from(
            document.querySelectorAll("[data-ad-break]"),
        ) as HTMLElement[];
        const data = items.map((el) => ({ name: el.dataset.name ?? "" }));

        input.addEventListener("input", () => {
            const q = input.value.trim();
            const noResults = document.getElementById("no-results")!;

            if (!q) {
                items.forEach((el) => (el.style.display = ""));
                adBreaks.forEach((el) => (el.style.display = ""));
                noResults.style.display = "none";
                return;
            }

            // hide ad breaks during search — chunks aren't meaningful when filtered
            adBreaks.forEach((el) => (el.style.display = "none"));

            const results = fuzzyFilter(data, q);
            const matchedNames = new Set(results.map((r) => r.name));
            const list = document.getElementById("subject-list")!;
            let any = false;
            items.forEach((el) => {
                const name = el.dataset.name ?? "";
                const show = matchedNames.has(name);
                el.style.display = show ? "" : "none";
                if (show) {
                    list.appendChild(el);
                    any = true;
                }
            });
            noResults.style.display = any ? "none" : "flex";
        });
    </script>

  <script>
    (async () => {
      const mounts = document.querySelectorAll("[data-ad-mount]");
      if (!mounts.length) return;
      const [{ default: FeaturedSlot }, { createElement }, { createRoot }] = await Promise.all([
        import("/src/components/Campaign"),
        import("react"),
        import("react-dom/client"),
      ]);
      mounts.forEach((el) => {
        createRoot(el).render(createElement(FeaturedSlot, { variant: "horizontal" }));
      });
    })();
  </script>
</BaseLayout>
