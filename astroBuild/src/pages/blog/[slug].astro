---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import FeaturedSlot from "../../components/Campaign";

export async function getStaticPaths() {
    const posts = await getCollection("blog", ({ data }) => {
        return import.meta.env.PROD ? data.draft !== true : true;
    });
    return posts.map((post) => ({
        params: { slug: post.id },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const dateStr = post.data.date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
});

// Sibling posts for sidebar
const allPosts = (
    await getCollection("blog", ({ data }) => {
        return import.meta.env.PROD ? data.draft !== true : true;
    })
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const currentIdx = allPosts.findIndex((p) => p.id === post.id);
const prevPost = allPosts[currentIdx + 1] ?? null;
const nextPost = allPosts[currentIdx - 1] ?? null;
---

<BaseLayout
    title={`${post.data.title} — Blog | Paper Guides`}
    description={post.data.description ?? `A blog post from Paper Guides.`}
>
    <!-- Header — matches question page style -->
    <div
        class="bg-[#242424] text-[#f7f7f7] py-12 md:py-14 lg:py-20 md:px-8 lg:px-14 xl:px-20 px-5 grid grid-cols-1 md:grid-cols-2 gap-12 items-center"
    >
        <div class="flex flex-col justify-center">
            <span
                class="text-[var(--muted)] mb-6 text-xs flex items-center gap-1 flex-wrap"
            >
                <a href="/"><i class="ph-fill ph-house"></i> Home</a> /
                <a href="/blog"><i class="ph-fill ph-pen-nib"></i> Blog</a> /
                <span
                    ><i class="ph-fill ph-file-text"></i>
                    {post.data.title}</span
                >
            </span>
            <h1 class="font-serif font-bold text-3xl md:text-5xl leading-snug">
                {post.data.title}
            </h1>
            <p class="mt-4 text-xs md:text-sm text-[var(--muted)] max-w-md">
                {post.data.description}
            </p>
            <div class="mt-6 flex items-center gap-3 flex-wrap">
                <span class="text-xs text-[var(--muted)] font-mono"
                    >{dateStr}</span
                >
                {
                    post.data.tags?.map((tag) => (
                        <span class="text-xs px-2 py-0.5 bg-[var(--muted)]/20 text-[var(--color-text)] rounded-full">
                            {tag}
                        </span>
                    ))
                }
            </div>
        </div>
    </div>

    <!-- Content + Sidebar — stretches full height, no gap to footer -->
    <div
        class="flex-1 grid grid-cols-1 lg:grid-cols-[1fr_360px] bg-[var(--baby-powder)] items-stretch min-h-0"
    >
        <!-- Post body -->
        <div
            class="bg-[var(--baby-powder)] px-5 md:px-8 lg:px-16 xl:px-24 py-6"
        >
            <article id="blog-content" class="prose-blog">
                <Content />
            </article>

            <!-- Inline ad — injected mid-article by JS on mobile/md; fallback shown for short posts -->
            <div id="blog-mid-ad" class="lg:hidden mt-8 pt-6 border-t border-[var(--border-subtle)]">
                <FeaturedSlot variant="horizontal" client:only="react" />
            </div>

            <!-- Prev / Next navigation — clean like question page -->
            <nav
                class="flex items-center justify-between mt-12 pt-6 border-t border-[var(--border-subtle)]"
            >
                {
                    prevPost ? (
                        <a
                            href={`/blog/${prevPost.id}`}
                            class="flex items-center gap-2 text-sm text-[var(--font-color)] hover:text-[var(--accent)] transition-colors group"
                        >
                            <i class="ph-fill ph-arrow-left transition-transform group-hover:-translate-x-1" />
                            <span class="flex flex-col">
                                <span class="text-xs text-[var(--muted)]">
                                    Older
                                </span>
                                <span class="line-clamp-1 max-w-[200px]">
                                    {prevPost.data.title}
                                </span>
                            </span>
                        </a>
                    ) : (
                        <div />
                    )
                }

                {
                    nextPost ? (
                        <a
                            href={`/blog/${nextPost.id}`}
                            class="flex items-center gap-2 text-sm text-[var(--font-color)] hover:text-[var(--accent)] transition-colors group text-right"
                        >
                            <span class="flex flex-col">
                                <span class="text-xs text-[var(--muted)]">
                                    Newer
                                </span>
                                <span class="line-clamp-1 max-w-[200px]">
                                    {nextPost.data.title}
                                </span>
                            </span>
                            <i class="ph-fill ph-arrow-right transition-transform group-hover:translate-x-1" />
                        </a>
                    ) : (
                        <div />
                    )
                }
            </nav>
        </div>

        <!-- Sidebar — sticky, clean, ordered like question page -->
        <aside
            class="hidden lg:flex flex-col gap-6 sticky top-[80px] self-start bg-[var(--sidebar-bg)] border-l border-[var(--border-subtle)] p-4 h-[calc(100vh-80px)] overflow-y-auto"
        >
            <!-- TOC header with print action -->
            <div
                class="flex justify-between items-center border-b border-[var(--border-subtle)] pb-2"
            >
                <p class="font-bold text-lg uppercase tracking-wide opacity-60">
                    On this page
                </p>
                <button
                    onclick="window.print()"
                    data-umami-event="Print Blog Post"
                    data-umami-event-post={post.data.title}
                    class="cursor-pointer px-4 py-2 rounded-xl bg-[var(--green-highlight)] text-white font-bold hover:opacity-80 transition-all duration-300 ease-out hover:shadow-xl hover:-translate-y-0.5 hover:scale-[1.02] outline outline-1 outline-[var(--border-subtle)]"
                >
                    <i class="ph-fill ph-printer"></i> Print
                </button>
            </div>

            <!-- TOC list — clean, numbered style -->
            {
                headings.length > 0 && (
                    <div class="border-b border-[var(--border-subtle)] pb-2">
                        <ul class="space-y-1 text-sm">
                            {headings.map((h, idx) => (
                                <li>
                                    <a
                                        href={`#${h.slug}`}
                                        class={[
                                            "flex gap-2 items-start py-1 hover:text-[var(--accent)] transition-colors",
                                            h.depth === 1
                                                ? "font-semibold"
                                                : h.depth === 2
                                                  ? "pl-4"
                                                  : "pl-7 text-[var(--muted)] text-xs",
                                        ].join(" ")}
                                    >
                                        <span class="font-mono text-xs text-[var(--muted)] shrink-0 mt-0.5">
                                            {String(idx + 1).padStart(2, "0")}.
                                        </span>
                                        <span class="line-clamp-2">
                                            {h.text}
                                        </span>
                                    </a>
                                </li>
                            ))}
                        </ul>
                    </div>
                )
            }

            <!-- More posts — only shown when there are other posts -->
            {
                allPosts.filter((p) => p.id !== post.id).length > 0 && (
                    <div class="border-b border-[var(--border-subtle)] pb-2 mb-2">
                        <h3 class="font-semibold border-b border-[var(--border-subtle)] pb-2 mb-2">
                            More posts
                        </h3>
                        <ul class="space-y-1 text-sm">
                            {allPosts
                                .filter((p) => p.id !== post.id)
                                .slice(0, 10)
                                .map((p) => (
                                    <li>
                                        <a
                                            href={`/blog/${p.id}`}
                                            class="flex gap-2 items-start py-1 hover:text-[var(--accent)] transition-colors hover:underline"
                                        >
                                            <span class="font-mono text-xs text-[var(--muted)] shrink-0 mt-0.5">
                                                {String(
                                                    allPosts.indexOf(p) + 1,
                                                ).padStart(2, "0")}
                                                .
                                            </span>
                                            <span class="line-clamp-2">
                                                {p.data.title}
                                            </span>
                                        </a>
                                    </li>
                                ))}
                        </ul>
                    </div>
                )
            }

            <!-- Sponsor Space — clean, at bottom -->
            <div
                class="text-sm text-[var(--muted)] text-center mt-auto pt-2 border-t border-[var(--border-subtle)]"
            >
                <FeaturedSlot client:only="react"/>
            </div>
        </aside>
    </div>
</BaseLayout>

<style>
    /* Blog prose styles — matches notes theme, clean & readable */
    .prose-blog :global(h1),
    .prose-blog :global(h2),
    .prose-blog :global(h3),
    .prose-blog :global(h4) {
        font-family: "Playfair Display", Georgia, serif;
        font-weight: 700;
        color: var(--color-text);
        margin-top: 2rem;
        margin-bottom: 0.75rem;
        scroll-margin-top: 90px;
    }
    .prose-blog :global(h1) {
        font-size: 2rem;
    }
    .prose-blog :global(h2) {
        font-size: 1.5rem;
        border-bottom: 1px solid var(--border-subtle);
        padding-bottom: 0.25rem;
    }
    .prose-blog :global(h3) {
        font-size: 1.2rem;
    }

    .prose-blog :global(p) {
        line-height: 1.8;
        margin-bottom: 1.2rem;
        color: var(--color-text);
    }

    .prose-blog :global(a) {
        color: var(--accent);
        text-decoration: underline;
        text-underline-offset: 2px;
    }

    .prose-blog :global(ul),
    .prose-blog :global(ol) {
        padding-left: 1.5rem;
        margin-bottom: 1.2rem;
        line-height: 1.8;
    }
    .prose-blog :global(ul) {
        list-style-type: disc;
    }
    .prose-blog :global(ol) {
        list-style-type: decimal;
    }

    .prose-blog :global(li) {
        margin-bottom: 0.3rem;
    }

    .prose-blog :global(blockquote) {
        border-left: 3px solid var(--accent);
        padding-left: 1rem;
        margin: 1.5rem 0;
        color: var(--muted);
        font-style: italic;
    }

    .prose-blog :global(code) {
        background: var(--color-surface);
        border: 1px solid var(--border-subtle);
        border-radius: 4px;
        padding: 0.1em 0.4em;
        font-size: 0.875em;
        font-family: "Courier New", monospace;
    }

    .prose-blog :global(pre) {
        background: #1e1e1e;
        color: #e2e0dc;
        padding: 1.25rem;
        border-radius: 8px;
        overflow-x: auto;
        margin-bottom: 1.5rem;
    }

    .prose-blog :global(pre code) {
        background: none;
        border: none;
        padding: 0;
        color: inherit;
        font-size: 0.9em;
    }

    .prose-blog :global(hr) {
        border: none;
        border-top: 1px solid var(--border-subtle);
        margin: 2rem 0;
    }

    .prose-blog :global(img) {
        max-width: 100%;
        border-radius: 8px;
        margin: 1.5rem auto;
        display: block;
        border: 1px solid var(--border-subtle);
    }

    .prose-blog :global(table) {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
    }
    .prose-blog :global(th) {
        background: var(--color-surface);
        border: 1px solid var(--border-subtle);
        padding: 0.5rem 0.75rem;
        text-align: left;
        font-weight: 600;
    }
    .prose-blog :global(td) {
        border: 1px solid var(--border-subtle);
        padding: 0.5rem 0.75rem;
    }
</style>

<script>
  // Move the mid-article ad to after the ~40% mark of paragraphs (mobile/md only)
  // Falls back to its original position (below article) if not enough content
  const midAd = document.getElementById("blog-mid-ad");
  const article = document.getElementById("blog-content");
  if (midAd && article && window.innerWidth < 1024) {
    const paras = Array.from(article.querySelectorAll("p, h2, h3, blockquote"));
    const insertAfter = Math.floor(paras.length * 0.4);
    if (insertAfter >= 2 && paras[insertAfter]) {
      paras[insertAfter].insertAdjacentElement("afterend", midAd);
      midAd.classList.remove("mt-8", "pt-6", "border-t");
      midAd.classList.add("my-8", "py-4", "border-y");
    }
  }
</script>
