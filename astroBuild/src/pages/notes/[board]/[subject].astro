---
import LevelTopicalsLayout from "../../../layouts/LevelTopicalsLayout.astro";
import BackButton from "../../../components/BackButton.astro";
import { getPaperIndex } from "../../../utils/paperIndex";
import { slugify, unslugify } from "../../../utils/slugify";
import BaseLayout from "../../../layouts/BaseLayout.astro";

export const prerender = false;

const { board, subject } = Astro.params;

let topics: { name: string; slug: string }[] = [];
let globalIndex: any;
let realSubjectName: string;

try {
  const index = await getPaperIndex();
  globalIndex = index;
  topics = index?.[board!]?.[subject!]?.["topics"] ?? [];
  topics = topics.sort((a: { name: string }, b: { name: string }) => a.name.localeCompare(b.name, undefined, { sensitivity: "base" }));
  realSubjectName =
    index?.[board!]?.[subject!]?.name ?? subject!.replace(/-/g, " ");
} catch (err) {
  console.error("Failed to fetch data:", err);
  realSubjectName = subject!.replace(/-/g, " ");
}

const boardDisplayName =
  board === "a-levels"
    ? "A Levels"
    : board === "kathmandu-university"
      ? "Kathmandu University"
      : board;

