---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getPaperIndex } from "../../../utils/paperIndex";
import { slugify } from "../../../utils/slugify";
import { getCollection } from "astro:content";
import FeaturedSlot from "../../../components/Campaign";

export async function getStaticPaths() {
    const index = await getPaperIndex();

    // Build the set of topics that have notes from the content collection
    const allNotes = await getCollection("notes");
    const noteTopics = new Set<string>(); // "board/subject/topicSlug"
    for (const note of allNotes) {
        const { board, subject, topic } = note.data;
        if (board && subject && topic) {
            noteTopics.add(`${board}/${subject}/${topic}`);
        }
    }

    const paths: any[] = [];

    for (const board in index) {
        for (const subjectKey in index[board]) {
            const subject = index[board][subjectKey];
            const topics = (subject.topics ?? []).map((t: any) => ({
                name: t.name,
                slug: t.slug,
                hasNote: noteTopics.has(`${board}/${subjectKey}/${t.slug}`),
            }));

            paths.push({
                params: { board, subject: subjectKey },
                props: {
                    subjectName: subject.name ?? subjectKey.replace(/-/g, " "),
                    topics,
                },
            });
        }
    }

    return paths;
}

const { board, subject } = Astro.params;
const { subjectName, topics } = Astro.props;

const boardDisplayName =
    board === "a-levels"
        ? "A Levels"
        : board === "kathmandu-university"
          ? "Kathmandu University"
          : board;

const notesCount = topics.filter((t: any) => t.hasNote).length;
// Chunk into 4 equal sections for inline ad breaks (only when list is long)
const CHUNK_SIZE_TOPICS = Math.ceil(topics.length / 4);
const USE_CHUNKS_TOPICS = topics.length > 40;
const chunks_topics: (typeof topics[0])[][] = [];
if (USE_CHUNKS_TOPICS) {
    for (let i = 0; i < topics.length; i += CHUNK_SIZE_TOPICS) {
        chunks_topics.push(topics.slice(i, i + CHUNK_SIZE_TOPICS));
    }
} else {
    chunks_topics.push([...topics]);
}

---

<BaseLayout
    title={`${subjectName} Notes | Paper Guides`}
    description={`Revision notes for ${subjectName} (${boardDisplayName}), organised by topic.`}
>
    <div class="mt-[64px] min-h-[calc(100vh-64px)] flex flex-col">
        <div
            class="bg-[#242424] text-[#f7f7f7] py-12 md:py-14 lg:py-20 md:px-8 lg:px-14 xl:px-20 px-5 grid grid-cols-1 md:grid-cols-2 gap-12 items-center"
        >
            <div class="flex flex-col justify-center">
                <span
                    class="text-[var(--muted)] mb-6 text-xs flex items-center gap-1"
                >
                    <a href="/"><i class="ph-fill ph-house"></i> Home</a> /
                    <a href="/notes"
                        ><i class="ph-fill ph-notebook"></i> Notes</a
                    > /
                    <a href={`/notes/${board}`}
                        ><i class="ph-fill ph-book"></i> {boardDisplayName}</a
                    > /
                    <span><i class="ph-fill ph-books"></i> {subjectName}</span>
                </span>
                <h1 class="font-serif font-bold text-4xl md:text-6xl">
                    {subjectName}<br />
                    <span class="text-[var(--accent)] italic">Notes</span>
                </h1>
                <p class="mt-4 text-xs md:text-sm text-[var(--muted)]">
                    {topics.length} topics · {notesCount} with notes available
                </p>
            </div>

            <div class="flex flex-col justify-end h-full gap-3">
                <span
                    class="text-xs text-[var(--muted)] uppercase tracking-widest"
                    >Find a topic</span
                >
                <input
                    type="text"
                    id="topic-search"
                    placeholder="Search topics..."
                    class="w-full bg-transparent border-b border-[var(--muted)] text-[#f7f7f7] placeholder:text-[var(--muted)] focus:outline-none focus:border-[var(--accent)] py-2 text-lg transition-colors duration-200"
                />
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-[1fr_360px] flex-1">
            <div id="topic-list" class="bg-[var(--baby-powder)] flex flex-col">
                <span
                    class="bg-[var(--color-surface)] text-sm text-[var(--muted)] uppercase tracking-widest px-5 md:px-8 lg:px-14 xl:px-20 py-3 border-b border-[var(--border-subtle)]"
                >
                    {
                        notesCount > 0
                            ? `${notesCount} of ${topics.length} topics have notes`
                            : `Notes coming soon for ${subjectName}`
                    }
                </span>

                {
                    chunks_topics.map((chunk, chunkIdx) => (
                        <div class="chunk-section">
                            {chunk.map((t: any) =>
                                t.hasNote ? (
                                    <a
                                        data-topic={t.slug}
                                        href={`/notes/${board}/${subject}/${slugify(t.slug)}`}
                                        class="group border-b border-[var(--border-subtle)] px-5 md:px-8 lg:px-14 xl:px-20 py-8
                                               bg-[var(--baby-powder)] hover:bg-gradient-to-r hover:from-[var(--baby-powder)] hover:to-[rgba(74,222,128,0.05)]
                                               hover:shadow-lg hover:scale-[1.02] hover:-translate-y-1
                                               flex items-center justify-between transition-all duration-300 ease-out"
                                    >
                                        <div class="flex items-center gap-3">
                                            <span class="font-bold text-xl group-hover:text-[var(--accent)] transition-colors">
                                                {t.name}
                                            </span>
                                            <span class="text-xs px-2 py-0.5 rounded-full bg-[var(--green-highlight)]/20 text-[var(--green-highlight)] font-semibold">
                                                Notes
                                            </span>
                                        </div>
                                        <i class="ph-fill ph-arrow-right text-[var(--muted)] text-2xl shrink-0 transition-all duration-300 group-hover:translate-x-2 group-hover:text-[var(--accent)]" />
                                    </a>
                                ) : (
                                    <div
                                        data-topic={t.slug}
                                        class="border-b border-[var(--border-subtle)] px-5 md:px-8 lg:px-14 xl:px-20 py-8 flex items-center justify-between opacity-35"
                                    >
                                        <span class="font-bold text-xl">{t.name}</span>
                                        <span class="text-xs text-[var(--muted)]">
                                            Coming soon
                                        </span>
                                    </div>
                                ),
                            )}
                            {chunkIdx < chunks_topics.length - 1 && (
                                <div class="ad-break border-b border-[var(--border-subtle)] px-5 md:px-8 lg:px-14 xl:px-20 py-5 bg-[var(--color-surface)]/50 flex items-center gap-5" data-ad-break>
                                    <div class="flex-1 h-px bg-[var(--border-subtle)]" />
                                    <FeaturedSlot variant="horizontal" client:only="react" />
                                    <div class="flex-1 h-px bg-[var(--border-subtle)]" />
                                </div>
                            )}
                        </div>
                    ))
                }

                {
                    topics.length === 0 && (
                        <div class="flex flex-col items-center justify-center py-24 gap-4 text-[var(--muted)]">
                            <i class="ph-fill ph-smiley-x-eyes text-6xl" />
                            <p class="text-sm">No topics available yet.</p>
                        </div>
                    )
                }

                <div
                    id="no-results"
                    class="hidden flex-col items-center justify-center py-24 gap-4 text-[var(--muted)]"
                >
                    <i class="ph-fill ph-smiley-x-eyes text-6xl"></i>
                    <p class="text-sm">No topics match your search.</p>
                </div>
            </div>

            <aside
                class="hidden lg:flex flex-col items-center gap-4 sticky top-[64px] self-start h-[calc(100vh-64px)] bg-[var(--nav-bg)] border-l border-[var(--border-subtle)] p-6"
            >
                <FeaturedSlot client:only="react" />
            </aside>
        </div>
    </div>

    <div
        class="lg:hidden w-full bg-[var(--nav-bg)] border-t border-[var(--border-subtle)] px-5 py-3 flex items-center justify-center"
    >
        <FeaturedSlot variant="horizontal" client:only="react" />
    </div>

    <script>
        import { fuzzyFilter } from "../../../utils/search";
        const input = document.getElementById(
            "topic-search",
        ) as HTMLInputElement;
        const items = Array.from(
            document.querySelectorAll("#topic-list [data-topic]"),
        ) as HTMLElement[];
        const adBreaks = Array.from(
            document.querySelectorAll("[data-ad-break]"),
        ) as HTMLElement[];
        const data = items.map((el) => ({ topic: el.dataset.topic ?? "" }));

        input.addEventListener("input", () => {
            const q = input.value.trim();
            const noResults = document.getElementById("no-results")!;
            if (!q) {
                items.forEach((el) => (el.style.display = ""));
                adBreaks.forEach((el) => (el.style.display = ""));
                noResults.style.display = "none";
                return;
            }
            adBreaks.forEach((el) => (el.style.display = "none"));
            // @ts-ignore
            const matched = new Set(
                fuzzyFilter(data, q, "topic").map((r) => r.topic),
            );
            let any = false;
            items.forEach((el) => {
                const show = matched.has(el.dataset.topic ?? "");
                el.style.display = show ? "" : "none";
                if (show) any = true;
            });
            noResults.style.display = any ? "none" : "flex";
        });
    </script>
</BaseLayout>