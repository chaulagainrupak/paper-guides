---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import FeaturedSlot from "../../../../components/Campaign";
import { getPaperIndex } from "../../../../utils/paperIndex";
import { slugify } from "../../../../utils/slugify";

export async function getStaticPaths() {
    const index = await getPaperIndex();
    const allNotes = await getCollection("notes");

    // Build a map: "board/subject/topicSlug" -> note entry
    const noteMap = new Map<string, (typeof allNotes)[0]>();
    for (const note of allNotes) {
        const { board, subject, topic } = note.data;
        if (board && subject && topic) {
            noteMap.set(`${board}/${subject}/${topic}`, note);
        }
    }

    const paths: any[] = [];

    for (const board in index) {
        for (const subjectKey in index[board]) {
            const subject = index[board][subjectKey];
            for (const t of subject.topics ?? []) {
                const key = `${board}/${subjectKey}/${t.slug}`;
                const note = noteMap.get(key);
                if (!note) continue; // only generate pages for topics that have notes

                const siblingTopics = (subject.topics ?? []).map((st: any) => ({
                    name: st.name,
                    slug: st.slug,
                    hasNote: noteMap.has(`${board}/${subjectKey}/${st.slug}`),
                }));

                paths.push({
                    params: { board, subject: subjectKey, topic: t.slug },
                    props: {
                        note,
                        topicName: t.name ?? t.slug.replace(/-/g, " "),
                        subjectName:
                            subject.name ?? subjectKey.replace(/-/g, " "),
                        siblingTopics,
                    },
                });
            }
        }
    }

    return paths;
}

const { board, subject, topic } = Astro.params;
const { note, topicName, subjectName, siblingTopics } = Astro.props;

const { Content, headings } = await render(note);

const boardDisplayName =
    board === "a-levels"
        ? "A Levels"
        : board === "kathmandu-university"
          ? "Kathmandu University"
          : board!.replace(/-/g, " ");

// Prev / next topic that also has notes
const currentIdx = siblingTopics.findIndex((t: any) => t.slug === topic);
const prevTopic =
    siblingTopics
        .slice(0, currentIdx)
        .reverse()
        .find((t: any) => t.hasNote) ?? null;
const nextTopic =
    siblingTopics.slice(currentIdx + 1).find((t: any) => t.hasNote) ?? null;
---

<BaseLayout
    title={`${topicName} — ${subjectName} Notes | Paper Guides`}
    description={`Revision notes for ${topicName} in ${subjectName} (${boardDisplayName}).`}
>
    <!-- Header -->
    <div
        class="bg-[#242424] text-[#f7f7f7] py-12 md:py-14 lg:py-20 md:px-8 lg:px-14 xl:px-20 px-5 grid grid-cols-1 md:grid-cols-2 gap-12 items-center"
    >
        <div class="flex flex-col justify-center">
            <span
                class="text-[var(--muted)] mb-6 text-xs flex items-center gap-1 flex-wrap"
            >
                <a href="/"><i class="ph-fill ph-house"></i> Home</a> /
                <a href="/notes"><i class="ph-fill ph-notebook"></i> Notes</a> /
                <a href={`/notes/${board}`}>{boardDisplayName}</a> /
                <a href={`/notes/${board}/${subject}`}>{subjectName}</a> /
                <span><i class="ph-fill ph-file-text"></i> {topicName}</span>
            </span>
            <h1 class="font-serif font-bold text-3xl md:text-5xl leading-snug">
                {topicName}
            </h1>
            <p class="mt-4 text-xs md:text-sm text-[var(--muted)] max-w-md">
                {subjectName} &middot; {boardDisplayName}
            </p>
        </div>
    </div>

    <!-- Content + Sidebar -->
    <div class="flex-1 grid grid-cols-1 lg:grid-cols-[1fr_360px]">
        <!-- Notes body -->
        <div
            class="bg-[var(--baby-powder)] px-5 md:px-8 lg:px-16 xl:px-24 py-6 shadow"
        >
            <article id="notes-content" class="prose-notes">
                <Content />
            </article>

            <!-- Prev / Next topic navigation -->
            <nav
                class="flex items-center justify-between mt-12 pt-6 border-t border-[var(--border-subtle)]"
            >
                {
                    prevTopic ? (
                        <a
                            href={`/notes/${board}/${subject}/${prevTopic.slug}`}
                            class="flex items-center gap-2 text-sm text-[var(--font-color)] hover:text-[var(--accent)] transition-colors group"
                        >
                            <i class="ph-fill ph-arrow-left transition-transform group-hover:-translate-x-1" />
                            <span class="flex flex-col">
                                <span class="text-xs text-[var(--muted)]">
                                    Previous
                                </span>
                                <span class="line-clamp-1 max-w-[200px]">
                                    {prevTopic.name}
                                </span>
                            </span>
                        </a>
                    ) : (
                        <div />
                    )
                }

                {
                    nextTopic ? (
                        <a
                            href={`/notes/${board}/${subject}/${nextTopic.slug}`}
                            class="flex items-center gap-2 text-sm text-[var(--font-color)] hover:text-[var(--accent)] transition-colors group text-right"
                        >
                            <span class="flex flex-col">
                                <span class="text-xs text-[var(--muted)]">
                                    Next
                                </span>
                                <span class="line-clamp-1 max-w-[200px]">
                                    {nextTopic.name}
                                </span>
                            </span>
                            <i class="ph-fill ph-arrow-right transition-transform group-hover:translate-x-1" />
                        </a>
                    ) : (
                        <div />
                    )
                }
            </nav>
        </div>

        <!-- Sidebar -->
        <aside
            class="hidden lg:flex flex-col gap-6 sticky top-[80px] self-start bg-[var(--sidebar-bg)] p-4 border-l border-[var(--border-subtle)] h-fit"
        >
            <!-- TOC -->
            <div
                class="flex justify-between items-center border-b border-[var(--border-subtle)] pb-2"
            >
                <p class="font-bold text-lg uppercase tracking-wide opacity-60">
                    On this page
                </p>
                <button
                    onclick="window.print()"
                    class="cursor-pointer px-4 py-2 rounded-xl bg-[var(--green-highlight)] text-white font-bold hover:opacity-80 transition-all duration-300 ease-out hover:shadow-xl hover:-translate-y-0.5 hover:scale-[1.02] outline outline-1 outline-[var(--border-subtle)]"
                >
                    <i class="ph-fill ph-printer"></i> Print
                </button>
            </div>

            {
                headings.length > 0 && (
                    <div class="border-b border-[var(--border-subtle)] pb-2">
                        <ul class="space-y-1 text-sm">
                            {headings.map((h, idx) => (
                                <li>
                                    <a
                                        href={`#${h.slug}`}
                                        class={[
                                            "flex gap-2 items-start py-1 hover:text-[var(--accent)] transition-colors",
                                            h.depth === 1
                                                ? "font-semibold"
                                                : h.depth === 2
                                                  ? "pl-4"
                                                  : "pl-7 text-[var(--muted)] text-xs",
                                        ].join(" ")}
                                    >
                                        <span class="font-mono text-xs text-[var(--muted)] shrink-0 mt-0.5">
                                            {String(idx + 1).padStart(2, "0")}.
                                        </span>
                                        <span class="line-clamp-2">
                                            {h.text}
                                        </span>
                                    </a>
                                </li>
                            ))}
                        </ul>
                    </div>
                )
            }

            <!-- Other topics in this subject -->
            {
                siblingTopics.filter((t: any) => t.slug !== topic && t.hasNote)
                    .length > 0 && (
                    <div class="border-b border-[var(--border-subtle)] pb-2 mb-2">
                        <h3 class="font-semibold border-b border-[var(--border-subtle)] pb-2 mb-2">
                            {subjectName}
                        </h3>
                        <ul class="space-y-1 text-sm">
                            {siblingTopics
                                .filter(
                                    (t: any) => t.slug !== topic && t.hasNote,
                                )
                                .map((t: any, idx: number) => (
                                    <li>
                                        <a
                                            href={`/notes/${board}/${subject}/${t.slug}`}
                                            class="flex gap-2 items-start py-1 hover:text-[var(--accent)] transition-colors hover:underline"
                                        >
                                            <span class="font-mono text-xs text-[var(--muted)] shrink-0 mt-0.5">
                                                {String(idx + 1).padStart(
                                                    2,
                                                    "0",
                                                )}
                                                .
                                            </span>
                                            <span class="line-clamp-2">
                                                {t.name}
                                            </span>
                                        </a>
                                    </li>
                                ))}
                        </ul>
                    </div>
                )
            }

            <!-- Ad slot -->
            <div class="mt-auto pt-2 border-t border-[var(--border-subtle)]">
                <FeaturedSlot client:only="react" />
            </div>
        </aside>
    </div>

    <!-- Mobile sponsor strip -->
    <div
        class="lg:hidden w-full bg-[var(--nav-bg)] border-t border-[var(--border-subtle)] px-5 py-4 flex items-center justify-center"
    >
        <FeaturedSlot variant="horizontal" client:only="react" />
    </div>
</BaseLayout>

<style>
    .prose-notes :global(h1),
    .prose-notes :global(h2),
    .prose-notes :global(h3),
    .prose-notes :global(h4) {
        font-family: "Playfair Display", Georgia, serif;
        font-weight: 700;
        color: var(--color-text);
        margin-top: 2rem;
        margin-bottom: 0.75rem;
        scroll-margin-top: 90px;
    }
    .prose-notes :global(h1) {
        font-size: 2rem;
    }
    .prose-notes :global(h2) {
        font-size: 1.5rem;
        border-bottom: 1px solid var(--border-subtle);
        padding-bottom: 0.25rem;
    }
    .prose-notes :global(h3) {
        font-size: 1.2rem;
    }

    .prose-notes :global(p) {
        line-height: 1.8;
        margin-bottom: 1.2rem;
        color: var(--color-text);
    }

    .prose-notes :global(a) {
        color: var(--accent);
        text-decoration: underline;
        text-underline-offset: 2px;
    }

    .prose-notes :global(ul),
    .prose-notes :global(ol) {
        padding-left: 1.5rem;
        margin-bottom: 1.2rem;
        line-height: 1.8;
    }
    .prose-notes :global(ul) {
        list-style-type: disc;
    }
    .prose-notes :global(ol) {
        list-style-type: decimal;
    }
    .prose-notes :global(li) {
        margin-bottom: 0.3rem;
    }

    .prose-notes :global(blockquote) {
        border-left: 3px solid var(--accent);
        padding-left: 1rem;
        margin: 1.5rem 0;
        color: var(--muted);
        font-style: italic;
    }

    .prose-notes :global(code) {
        background: var(--color-surface);
        border: 1px solid var(--border-subtle);
        border-radius: 4px;
        padding: 0.1em 0.4em;
        font-size: 0.875em;
        font-family: "Courier New", monospace;
    }

    .prose-notes :global(pre) {
        background: #1e1e1e;
        color: #e2e0dc;
        padding: 1.25rem;
        border-radius: 8px;
        overflow-x: auto;
        margin-bottom: 1.5rem;
    }

    .prose-notes :global(pre code) {
        background: none;
        border: none;
        padding: 0;
        color: inherit;
        font-size: 0.9em;
    }

    .prose-notes :global(hr) {
        border: none;
        border-top: 1px solid var(--border-subtle);
        margin: 2rem 0;
    }

    .prose-notes :global(img) {
        max-width: 100%;
        border-radius: 8px;
        margin: 1.5rem auto;
        display: block;
        border: 1px solid var(--border-subtle);
    }

    .prose-notes :global(table) {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
    }
    .prose-notes :global(th) {
        background: var(--color-surface);
        border: 1px solid var(--border-subtle);
        padding: 0.5rem 0.75rem;
        text-align: left;
        font-weight: 600;
    }
    .prose-notes :global(td) {
        border: 1px solid var(--border-subtle);
        padding: 0.5rem 0.75rem;
    }
</style>
