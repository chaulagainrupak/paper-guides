---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { API_URL } from "../../utils/config";

let boardsData: Record<string, any> = {};

try {
  const res = await fetch(API_URL + "/notes");
  boardsData = await res.json();
} catch (err) {
  console.error("Failed to fetch boards:", err);
}
---

<BaseLayout
  title="Paper Guides | Notes"
  description="Free exam preparation resources — Revision notes for A-Levels, Kathmandu University and more."
>
  <div class="mt-[64px] min-h-[calc(100vh-64px)] grid grid-cols-1 md:grid-cols-[1fr_1fr] grid-rows-auto md:grid-rows-[1fr_1fr]">
    <!-- Hero Section -->
    <div class="md:px-30 px-5 flex flex-col justify-center col-span-1 md:col-span-2 bg-[#242424] text-[#f7f7f7] py-12 md:py-20">
      <span class="text-[var(--muted)] mb-6 text-xs flex items-center gap-1">
        <a href="/"><i class="ph-fill ph-house"></i> Home</a> / <a href="/notes"><i class="ph-fill ph-notebook"></i> Notes</a>
      </span>
      <h1 class="font-serif font-bold text-4xl md:text-6xl">
        Revision <br />
        <span class="text-[var(--accent)] italic">Notes</span>
      </h1>
      <p class="mt-4 text-xs md:text-sm text-[var(--muted)] max-w-md">
        Paper Guides provides free, structured revision notes for students
        preparing for CAIE A Level exams and Kathmandu University Bachelors programmes.
        Notes are organised by board, subject, and topic for quick, easy access.
      </p>
    </div>

    <!-- CAIE A Levels Card -->
    <a class="group board-card p-6 md:p-20 bg-[var(--baby-powder)] transition-all duration-300 hover:translate-y-1 hover:shadow-xl md:border-r border-b border-t border-slate-200/60 hover:border-slate-300 relative overflow-hidden"
       href="/notes/a-levels">
      <div class="transition-all duration-300 pointer-events-none"></div>
      <div class="board-tag text-[var(--accent)] text-xs px-2 py-1 bg-[var(--accent)]/30 w-fit rounded-full font-semibold relative z-10">
        CAIE
      </div>
      <h2 class="board-h font-serif text-2xl md:text-4xl mt-4 mb-4 font-bold relative z-10">
        A Levels
      </h2>
      <p class="board-p text-xs md:text-sm text-[var(--muted)] max-w-md relative z-10">
        Access concise revision notes covering the full syllabus for core subjects
        including Mathematics, Physics, Chemistry, Biology, and Economics.
        Notes are broken down topic by topic for fast, effective study.
      </p>
      <div class="board-meta flex flex-col md:flex-row justify-end mt-6 gap-4 md:gap-0 md:text-center relative z-10">
        <i class="ph-fill ph-arrow-right text-[var(--muted)] text-2xl md:text-4xl shrink-0 md:mt-1 transition-all duration-300 group-hover:translate-x-1 group-hover:text-[var(--accent)]"></i>
      </div>
    </a>

    <!-- KU Bachelors Card -->
    <a class="group board-card p-6 md:p-20 bg-[var(--baby-powder)] transition-all duration-300 hover:translate-y-1 hover:shadow-xl md:border-r border-b border-t border-slate-200/60 hover:border-slate-300 relative overflow-hidden"
       href="/notes/kathmandu-university">
      <div class="transition-all duration-300 pointer-events-none"></div>
      <div class="board-tag text-[#1a5c52] text-xs px-2 py-1 bg-[#1a5c52]/30 w-fit rounded-full font-semibold relative z-10">
        KU
      </div>
      <h2 class="board-h font-serif text-2xl md:text-4xl mt-4 mb-4 font-bold relative z-10">
        KU Bachelors
      </h2>
      <p class="board-p text-xs md:text-sm text-[var(--muted)] max-w-md relative z-10">
        KU Bachelors notes are organised by semester and topic.
        Content is aligned with the current KU curriculum and covers core
        engineering and science subjects for efficient revision.
      </p>
      <div class="board-meta flex flex-col md:flex-row justify-end mt-6 gap-4 md:gap-0 md:text-center relative z-10">
        <i class="ph-fill ph-arrow-right text-[var(--muted)] text-2xl md:text-4xl shrink-0 md:mt-1 transition-all duration-300 group-hover:translate-x-1 group-hover:text-[#1a5c52]"></i>
      </div>
    </a>
  </div>
</BaseLayout>