
---
import LevelTopicalsLayout from '../../layouts/LevelTopicalsLayout.astro';
import BackButton from '../../components/BackButton.astro';
import { API_URL } from '../../utils/config';

let boardsData: Record<string, any> = {};

try {
  const res = await fetch(API_URL + '/pastpapers');
  boardsData = await res.json();
} catch (err) {
  console.error('Failed to fetch boards:', err);
}
---

<LevelTopicalsLayout
  title="Paper Guides | Notes"
  description="Free study notes for O-Level, A-Levels, NEB / TU / IOE and more."
>
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-4xl font-semibold">
      Available <span class="text-[var(--blue-highlight)]">Notes</span>
    </h1>
    <BackButton />
  </div>

  <div class="animate-fade-in space-y-6">
    {Object.entries(boardsData).map(([boardName, _]) => (
      <div class="board-section">
        <h2 class="text-4xl font-bold mb-2">{boardName}</h2>

        {boardName.toLowerCase() === 'a levels' && (
          <div class="mb-4">
            <a
              href="/notes/a-levels"
              class="border border-[var(--blue-highlight)] block p-4 rounded-xl w-full text-xl font-bold bg-[var(--color-nav)] text-[var(--font-color)] shadow-xl hover:scale-[1.01] hover:shadow-xl transition-all duration-200"
            >
              CAIE: A Levels
            </a>
          </div>
        )}

        {boardName.toLowerCase() === 'kathmandu university' && (
          <div>
            <a
              href="/notes/kathmandu-university"
              class="border border-[var(--blue-highlight)] block p-4 rounded-xl w-full text-xl font-bold bg-[var(--color-nav)] text-[var(--font-color)] shadow-xl hover:scale-[1.01] hover:shadow-xl transition-all duration-200"
            >
              KU: Bachelors
            </a>
          </div>
        )}
      </div>
    ))}
  </div>
</LevelTopicalsLayout>

