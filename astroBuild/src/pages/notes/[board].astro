---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPaperIndex } from "../../utils/paperIndex";
import FeaturedSlot from "../../components/Campaign";

export async function getStaticPaths() {
    const index = await getPaperIndex();

    return Object.keys(index).map((board) => {
        const subjects = Object.entries(index[board]).map(
            ([key, val]: [string, any]) => ({
                key,
                name: val.name ?? key.replace(/-/g, " "),
                topicCount: val.topics?.length ?? 0,
            }),
        );

        return {
            params: { board },
            props: { subjects },
        };
    });
}

const { board } = Astro.params;
const { subjects } = Astro.props;

const boardDisplayName =
    board === "a-levels"
        ? "A Levels"
        : board === "kathmandu-university"
          ? "Kathmandu University"
          : board;
// Chunk into 4 equal sections for inline ad breaks (only when list is long)
const CHUNK_SIZE_SUBJECTS = Math.ceil(subjects.length / 4);
const USE_CHUNKS_SUBJECTS = subjects.length > 40;
const chunks_subjects: (typeof subjects[0])[][] = [];
if (USE_CHUNKS_SUBJECTS) {
    for (let i = 0; i < subjects.length; i += CHUNK_SIZE_SUBJECTS) {
        chunks_subjects.push(subjects.slice(i, i + CHUNK_SIZE_SUBJECTS));
    }
} else {
    chunks_subjects.push([...subjects]);
}

---

<BaseLayout
    title={`${boardDisplayName} Notes | Paper Guides`}
    description={`Browse all ${boardDisplayName} subjects with revision notes on Paper Guides.`}
>
    <div class="mt-[64px] min-h-[calc(100vh-64px)] flex flex-col">
        <div
            class="bg-[#242424] text-[#f7f7f7] py-12 md:py-14 lg:py-20 md:px-8 lg:px-14 xl:px-20 px-5"
        >
            <span
                class="text-[var(--muted)] mb-6 text-xs flex items-center gap-1"
            >
                <a href="/"><i class="ph-fill ph-house"></i> Home</a> /
                <a href="/notes"><i class="ph-fill ph-notebook"></i> Notes</a> /
                <span><i class="ph-fill ph-book"></i> {boardDisplayName}</span>
            </span>
            <h1 class="font-serif font-bold text-4xl md:text-6xl mt-6">
                {boardDisplayName}<br />
                <span class="text-[var(--accent)] italic">Notes</span>
            </h1>
            <p class="mt-4 text-xs md:text-sm text-[var(--muted)]">
                {subjects.length} subjects available.
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-[1fr_360px] flex-1">
            <div class="bg-[var(--baby-powder)] flex flex-col">
                <span
                    class="bg-[var(--color-surface)] text-sm text-[var(--muted)] uppercase tracking-widest px-5 md:px-8 lg:px-14 xl:px-20 py-3 border-b border-[var(--border-subtle)]"
                >
                    Pick a subject
                </span>

                {
                    chunks_subjects.map((chunk, chunkIdx) => (
                        <div class="chunk-section">
                            {chunk.map((s) => (
                                <a
                                    href={`/notes/${board}/${s.key}`}
                                    class="group border-b border-[var(--border-subtle)] px-5 md:px-8 lg:px-14 xl:px-20 py-8
                                           bg-[var(--baby-powder)] hover:bg-gradient-to-r hover:from-[var(--baby-powder)] hover:to-[rgba(201,79,30,0.04)]
                                           hover:shadow-lg hover:scale-[1.02] hover:-translate-y-1
                                           flex items-center justify-between transition-all duration-300 ease-out"
                                >
                                    <div class="flex flex-col gap-1">
                                        <span class="font-bold text-xl group-hover:text-[var(--accent)] transition-colors">
                                            {s.name}
                                        </span>
                                        <span class="text-xs text-[var(--muted)]">
                                            {s.topicCount} topics
                                        </span>
                                    </div>
                                    <i class="ph-fill ph-arrow-right text-[var(--muted)] text-2xl shrink-0 transition-all duration-300 group-hover:translate-x-2 group-hover:text-[var(--accent)]" />
                                </a>
                            ))}
                            {chunkIdx < chunks_subjects.length - 1 && (
                                <div class="ad-break border-b border-[var(--border-subtle)] px-5 md:px-8 lg:px-14 xl:px-20 py-5 bg-[var(--color-surface)]/50 flex items-center gap-5" data-ad-break>
                                    <div class="flex-1 h-px bg-[var(--border-subtle)]" />
                                    <div data-ad-mount class="max-w-2xl w-full"></div>
                                    <div class="flex-1 h-px bg-[var(--border-subtle)]" />
                                </div>
                            )}
                        </div>
                    ))
                }
            </div>

            <aside
                class="hidden lg:flex flex-col items-center gap-4 sticky top-[64px] self-start h-[calc(100vh-64px)] bg-[var(--nav-bg)] border-l border-[var(--border-subtle)] p-6"
            >
                <FeaturedSlot client:only="react" />
            </aside>
        </div>
    </div>

    <div
        class="lg:hidden w-full bg-[var(--nav-bg)] border-t border-[var(--border-subtle)] px-5 py-3 flex items-center justify-center"
    >
        <FeaturedSlot variant="horizontal" client:only="react" />
    </div>

  <script>
    (async () => {
      const mounts = document.querySelectorAll("[data-ad-mount]");
      if (!mounts.length) return;
      const [{ default: FeaturedSlot }, { createElement }, { createRoot }] = await Promise.all([
        import("/src/components/Campaign"),
        import("react"),
        import("react-dom/client"),
      ]);
      mounts.forEach((el) => {
        createRoot(el).render(createElement(FeaturedSlot, { variant: "horizontal" }));
      });
    })();
  </script>
</BaseLayout>
