---
import type { GetStaticPaths } from 'astro';
import LevelTopicalsLayout from '../../layouts/LevelTopicalsLayout.astro';
import BackButton from '../../components/BackButton.astro';
import SubjectSearch from '../../components/SubjectSearch';
import { getPaperIndex } from '../../utils/paperIndex';

const { board } = Astro.params;

const boardNameMap: Record<string, string> = {
  'a-levels': 'A Levels',
  'kathmandu-university': 'kathmandu university',
  ioe: 'IOE',
};

const apiBoardName = boardNameMap[board!] ?? board!;

let subjects: { name: string }[] = [];

try {
  const index = await getPaperIndex();

  const notes = index?.notes?.[board!] ?? {};

  subjects = Object.keys(notes)
    .map((s) => ({
      name: s.replace(/-/g, ' '),
    }))
    .sort((a, b) =>
      a.name.localeCompare(b.name, undefined, { sensitivity: 'base' })
    );
} catch (err) {
  console.error('Failed to load notes subjects:', err);
}

export const getStaticPaths: GetStaticPaths = async () => {
  const index = await getPaperIndex();

  const boards = Object.keys(index?.notes ?? {});

  return boards.map((board) => ({
    params: { board },
  }));
};
---

<LevelTopicalsLayout
  title={`Notes — ${apiBoardName} | Paper Guides`}
  description={`Study notes for ${apiBoardName} subjects.`}
>
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-4xl font-semibold">
      <span class="text-[var(--blue-highlight)]">Notes</span> for: {apiBoardName}
    </h1>
    <BackButton />
  </div>

  <!-- @ts-ignore -->
  <SubjectSearch
    client:load
    subjects={subjects}
    boardSlug={board!}
    basePath={`/notes/${board}`}
  />
</LevelTopicalsLayout>