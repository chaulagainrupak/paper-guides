---
export const prerender = false;

import BaseLayout from "../../../../../layouts/BaseLayout.astro";
import MarkdownRenderer from "../../../../../components/MarkdownRenderer";
import { getPaperIndex } from "../../../../../utils/paperIndex";
import { slugify } from "../../../../../utils/slugify";
import { API_URL } from "../../../../../utils/config";

const { board, subject, topic, slug } = Astro.params;

const index = await getPaperIndex();

let realSubjectName: string =
  index?.[board!]?.[subject!]?.name ?? subject!.replace(/-/g, " ");

let topicList: {
  name: string;
  slug: string;
  questions?: { slug: string; title: string }[];
}[] = index?.[board!]?.[subject!]?.["topics"] ?? [];

const currentTopic = topicList.find((t) => t.slug === topic);
let realTopicName: string = currentTopic?.name ?? topic!.replace(/-/g, " ");
let questions: { slug: string; title: string }[] =
  currentTopic?.questions ?? [];

const currentQuestion = questions.find((q) => q.slug === slug);
let questionTitle: string = currentQuestion?.title ?? "";
const currentIndex = questions.findIndex((q) => q.slug === slug);
const prevQuestion = currentIndex > 0 ? questions[currentIndex - 1] : null;
const nextQuestion =
  currentIndex < questions.length - 1 ? questions[currentIndex + 1] : null;

let questionContent = "";
let error = "";
let questionData;
try {
  const res = await fetch(
    `${API_URL}/getQuestion/${encodeURIComponent(slug!)}`,
  );
  if (res.ok) {
    const data = await res.json();
    questionData = data;
    // questionContent = data.content ?? data.html ?? data.answer ?? "";
  } else {
    error = "Failed to load question.";
  }
} catch {
  error = "Failed to load question.";
}

const boardDisplayName =
  board === "a-levels"
    ? "A Levels"
    : board === "kathmandu-university"
      ? "Kathmandu University"
      : board;
---

<BaseLayout
  title={`${questionTitle || "Question"} — ${realTopicName} | Paper Guides`}
  description={`Past-paper question and answer for ${realTopicName} in ${realSubjectName}.`}
>
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/katex@0.16.10/dist/katex.min.css"
    crossorigin="anonymous"
  />
  <script
    defer
    src="https://cdn.jsdelivr.net/npm/katex@0.16.10/dist/katex.min.js"
    crossorigin="anonymous"></script>
  <script
    defer
    src="https://cdn.jsdelivr.net/npm/marked@12.0.0/marked.min.js"
    crossorigin="anonymous"></script>

  <div
    class="bg-[#242424] text-[#f7f7f7] py-12 md:py-20 md:px-20 px-5 grid grid-cols-1 md:grid-cols-2 gap-12 items-center"
  >
    <div class="flex flex-col justify-center">
      <span
        class="text-[var(--muted)] mb-6 text-xs flex items-center gap-1 flex-wrap"
      >
        <a href="/"><i class="ph-fill ph-house"></i> Home</a> /
        <a href="/questions"><i class="ph-fill ph-question"></i> Questions</a> /
        <a href={`/questions/${board}`}
          ><i class="ph-fill ph-book"></i> {boardDisplayName}</a
        > /
        <a href={`/questions/${board}/${subject}`}
          ><i class="ph-fill ph-books"></i> {realSubjectName}</a
        > /
        <a href={`/questions/${board}/${subject}/${topic}`}
          ><i class="ph-fill ph-file-text"></i> {realTopicName}</a
        > /
        <span
          ><i class="ph-fill ph-chat-centered-text"></i> Question {
            currentIndex + 1
          }</span
        >
      </span>
      <h1 class="font-serif font-bold text-3xl md:text-5xl leading-snug">
        {realSubjectName},<br />
        <span class="text-[var(--accent)] italic text-2xl md:text-3xl"
          >{realTopicName}</span
        >
      </h1>
      <p class="mt-4 text-xs md:text-sm text-[var(--muted)]">
        Question {currentIndex + 1} of {questions.length} in {realTopicName}.
      </p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-[1fr_360px]">
    <div class="bg-[var(--baby-powder)] px-5 md:px-25 py-6 shadow">
      <div id="question-content" class="printable-area">
        <!-- QUESTION -->
        {questionData[8]}
        <!-- answer -->
        {questionData[9]}
      </div>

      <div
        class="flex items-center justify-between mt-12 pt-6 border-t border-[var(--border-subtle)]"
      >
        {
          prevQuestion ? (
            <a
              href={`/questions/${board}/${subject}/${topic}/${prevQuestion.slug}`}
              class="flex items-center gap-2 text-sm text-[var(--font-color)] hover:text-[var(--accent)] transition-colors group"
            >
              <i class="ph-fill ph-arrow-left transition-transform group-hover:-translate-x-1" />
              <span class="flex flex-col">
                <span class="text-xs text-[var(--muted)]">Previous</span>
                <span class="line-clamp-1 max-w-[200px]">
                  {prevQuestion.title.length > 60
                    ? prevQuestion.title.slice(0, 60).trimEnd() + "…"
                    : prevQuestion.title}
                </span>
              </span>
            </a>
          ) : (
            <div />
          )
        }

        {
          nextQuestion ? (
            <a
              href={`/questions/${board}/${subject}/${topic}/${nextQuestion.slug}`}
              class="flex items-center gap-2 text-sm text-[var(--font-color)] hover:text-[var(--accent)] transition-colors group text-right"
            >
              <span class="flex flex-col">
                <span class="text-xs text-[var(--muted)]">Next</span>
                <span class="line-clamp-1 max-w-[200px]">
                  {nextQuestion.title.length > 60
                    ? nextQuestion.title.slice(0, 60).trimEnd() + "…"
                    : nextQuestion.title}
                </span>
              </span>
              <i class="ph-fill ph-arrow-right transition-transform group-hover:translate-x-1" />
            </a>
          ) : (
            <div />
          )
        }
      </div>

      <section class="mt-8 text-sm leading-relaxed space-y-4 opacity-80">
        <h2 class="font-semibold text-[var(--blue-highlight)]">
          {realTopicName} — {boardDisplayName}
        </h2>
        <p>
          Past-paper question and model answer for <strong
            >{realTopicName}</strong
          > in <strong>{realSubjectName}</strong>. Use these to practise and
          improve your exam technique.
        </p>
      </section>
    </div>

    <aside
      class="hidden md:flex flex-col gap-6 sticky top-[80px] self-start bg-[var(--sidebar-bg)] p-4"
    >
      <div
        class="flex justify-between items-center border-b border-[var(--border-subtle)] pb-2"
      >
        <p class="font-bold text-lg uppercase tracking-wide opacity-60">
          Questions
        </p>
        <button
          onclick="window.print()"
          class="cursor-pointer px-4 py-2 rounded-xl bg-[var(--green-highlight)] text-white font-bold hover:opacity-80 transition-all duration-300 ease-out hover:shadow-xl hover:-translate-y-0.5 hover:scale-[1.02]
                 bg-[var(--color-surface)] outline outline-1 outline-[var(--border-subtle)]"
        >
          <i class="ph-fill ph-printer"></i> Print
        </button>
      </div>

      <div class="border-b border-[var(--border-subtle)] pb-2">
        <ul class="space-y-1 text-sm">
          {
            questions.map((q, i) => (
              <li>
                <a
                  href={`/questions/${board}/${subject}/${topic}/${q.slug}`}
                  class={[
                    "flex gap-2 items-start py-1 hover:text-[var(--accent)] transition-colors",
                    q.slug === slug ? "text-[var(--accent)] font-semibold" : "",
                  ].join(" ")}
                >
                  <span class="font-mono text-xs text-[var(--muted)] shrink-0 mt-0.5">
                    {i + 1}.
                  </span>
                  <span class="line-clamp-2">
                    {q.title.length > 80
                      ? q.title.slice(0, 80).trimEnd() + "…"
                      : q.title}
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="border-b border-[var(--border-subtle)] pb-2 mb-2">
        <h3
          class="font-semibold border-b border-[var(--border-subtle)] pb-2 mb-2"
        >
          Other Topics in <a href={`/questions/${board}/${subject}`}
            >{realSubjectName}</a
          >
        </h3>
        <ul class="space-y-1 text-sm">
          {
            topicList
              .filter((t) => t.slug !== topic)
              .slice(0, 10)
              .map((t) => (
                <li>
                  <a
                    href={`/questions/${board}/${subject}/${slugify(t.slug)}`}
                    class="hover:underline"
                  >
                    {t.name}
                  </a>
                </li>
              ))
          }
        </ul>
      </div>

      <div class="text-sm text-[var(--muted)] text-center">Sponsor Space</div>
    </aside>
  </div>

  <div
    class="md:hidden w-full bg-[var(--nav-bg)] border-t border-[var(--border-subtle)] px-5 py-3 text-center text-sm text-[var(--muted)]"
  >
    Sponsor Space
  </div>
</BaseLayout>
