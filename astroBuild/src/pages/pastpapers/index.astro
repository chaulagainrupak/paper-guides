---
import BaseLayout from "../../layouts/BaseLayout.astro";

const pageTitle =
  "A Levels & Kathmandu University Past Papers | All Subjects & Years | Paper Guides";

const pageDescription =
  "Browse A Levels and Kathmandu University past papers organised by board, subject, and year. Access structured exam papers, downloadable questions, and revision materials designed to help students prepare effectively for exams.";

const pageKeywords = [
  "past papers",
  "A Levels past papers",
  "Kathmandu University past papers",
  "CAIE past papers",
  "KU past papers",
  "exam practice papers",
  "previous exam papers",
  "download past papers",
  "subject-wise past papers",
  "year-wise past papers",
];
const canonicalUrl = "https://paperguides.org/pastpapers";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  keywords={pageKeywords}
>
  <div
    class="mt-[64px] min-h-[calc(100vh-64px)] grid grid-cols-1 md:grid-cols-[1fr_1fr] grid-rows-auto md:grid-rows-[1fr_1fr]"
  >
    <!-- Hero Section -->
    <div
      class="md:px-30 px-5 flex flex-col justify-center col-span-1 md:col-span-2 bg-[#242424] text-[#f7f7f7] py-12 md:py-20"
    >
      <nav class="text-[var(--muted)] mb-6 text-xs flex items-center gap-1">
        <a href="/"><i class="ph-fill ph-house"></i> Home</a> /
        <a href="/pastpapers"><i class="ph-fill ph-exam"></i> Past Papers</a>
      </nav>
      <h1 class="font-serif font-bold text-4xl md:text-6xl">
        A Levels & Kathmandu University <br />
        <span class="text-[var(--accent)] italic"> Past Papers </span>
      </h1>
      <p class="mt-4 text-xs md:text-sm text-[var(--muted)] max-w-md">
        Free access to structured past papers for A Levels and Kathmandu
        University, organised by board, subject, and year. Each section provides
        exam-style questions sorted for efficient revision, allowing students to
        practise past exam papers, identify weak areas, and improve exam
        performance.
      </p>
    </div>

    <!-- A Levels -->
    <a
      class="group board-card p-6 md:p-20 bg-[var(--baby-powder)] transition-all duration-300 hover:translate-y-1 hover:shadow-xl md:border-r border-b border-t border-slate-200/60 hover:border-slate-300 relative overflow-hidden"
      href="/subjects/a-levels"
    >
      <div
        class="board-tag text-[var(--accent)] text-xs px-2 py-1 bg-[var(--accent)]/30 w-fit rounded-full font-semibold relative z-10"
      >
        CAIE
      </div>
      <h2
        class="board-h font-serif text-2xl md:text-4xl mt-4 mb-4 font-bold relative z-10"
      >
        A Levels
      </h2>
      <p
        class="board-p text-xs md:text-sm text-[var(--muted)] max-w-md relative z-10"
      >
        Past papers across 14 subjects from 2016 to present. Practise exam-style
        questions to prepare for upcoming exams.
      </p>
      <div
        class="board-meta flex flex-col md:flex-row justify-between mt-6 gap-4 md:gap-0 md:text-center relative z-10"
      >
        <div class="flex flex-col md:flex-row gap-4 md:gap-0">
          <div class="md:px-4 md:border-r border-slate-300/50 md:pr-2">
            <div class="font-serif text-xl md:text-2xl font-bold">14</div>
            <div class="text-xs text-[var(--muted)]">Subjects</div>
          </div>
          <div class="md:px-4 md:border-r border-slate-300/50 md:pr-2">
            <div class="font-serif text-xl md:text-2xl font-bold">9+</div>
            <div class="text-xs text-[var(--muted)]">Years</div>
          </div>
          <div class="md:px-4">
            <div class="font-serif text-xl md:text-2xl font-bold">P1–P5</div>
            <div class="text-xs text-[var(--muted)]">Components</div>
          </div>
        </div>
        <i
          class="ph-fill ph-arrow-right text-[var(--muted)] text-2xl md:text-4xl shrink-0 md:mt-1 transition-all duration-300 group-hover:translate-x-1 group-hover:text-[var(--accent)]"
        ></i>
      </div>
    </a>

    <!-- Kathmandu University -->
    <a
      class="group board-card p-6 md:p-20 bg-[var(--baby-powder)] transition-all duration-300 hover:translate-y-1 hover:shadow-xl md:border-r border-b border-t border-slate-200/60 hover:border-slate-300 relative overflow-hidden"
      href="/subjects/kathmandu-university"
    >
      <div
        class="board-tag text-[#1a5c52] text-xs px-2 py-1 bg-[#1a5c52]/30 w-fit rounded-full font-semibold relative z-10"
      >
        KU
      </div>
      <h2
        class="board-h font-serif text-2xl md:text-4xl mt-4 mb-4 font-bold relative z-10"
      >
        KU Bachelors
      </h2>
      <p
        class="board-p text-xs md:text-sm text-[var(--muted)] max-w-md relative z-10"
      >
        Past papers organised by faculty and semester. Covering core engineering
        subjects for efficient exam practice.
      </p>
      <div
        class="board-meta flex flex-col md:flex-row justify-between mt-6 gap-4 md:gap-0 md:text-center relative z-10"
      >
        <div class="flex flex-col md:flex-row gap-4 md:gap-0">
          <div class="md:px-4 md:border-r border-slate-300/50 md:pr-2">
            <div class="font-serif text-xl md:text-2xl font-bold">BIT</div>
            <div class="text-xs text-[var(--muted)]">& More faculties</div>
          </div>
          <div class="md:px-4">
            <div class="font-serif text-xl md:text-2xl font-bold">Sem 1–8</div>
            <div class="text-xs text-[var(--muted)]">All semesters</div>
          </div>
        </div>
        <i
          class="ph-fill ph-arrow-right text-[var(--muted)] text-2xl md:text-4xl shrink-0 md:mt-1 transition-all duration-300 group-hover:translate-x-1 group-hover:text-[#1a5c52]"
        ></i>
      </div>
    </a>
  </div>

  <section class="sr-only">
    <h2>A Levels and Kathmandu University Past Papers</h2>

    <p>
      This page provides structured access to past papers for A Levels and
      Kathmandu University programmes. Students can browse subjects, select
      specific years, and access past examination papers organised for efficient
      study and exam preparation.
    </p>

    <p>
      A Levels past papers include multiple subjects with papers sorted by
      component and year, supporting consistent revision and exam practice.
      Kathmandu University past papers are organised by faculty, subject, and
      semester to help university students prepare for internal and external
      examinations.
    </p>

    <p>
      Regular practice using past exam papers helps students understand exam
      patterns, improve time management, and build confidence before upcoming
      examinations.
    </p>
  </section>
</BaseLayout>
