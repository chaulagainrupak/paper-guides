---
export const prerender = true;

import { getPaperIndex } from "../utils/paperIndex";

type Paper = {
    name?: string;
};

type YearData = {
    papers?: Record<string, Paper>;
};

type TopicItem = {
    name: string;
    slug: string;
    notes?: { name: string; slug: string }[];
    questions?: { name: string; slug: string }[];
};

type SubjectData = {
    years?: Record<string, YearData>;
    topics?: TopicItem[];
};

type IndexType = Record<string, Record<string, SubjectData>>;

let index: IndexType = {};

try {
    index = await getPaperIndex();
} catch (err) {
    console.error("Failed to load index:", err);
}

export const getStaticPaths = async () => {
    return [{ params: {} }];
};

const format = (str: string) => str.replace(/-/g, " ");

const pageTitle = "All Past Papers, Notes & Questions | Exam Preparation";
const pageDescription =
    "Browse every past paper, topic note, and practice question available across all boards and subjects. Free exam preparation resources.";
const canonicalUrl = "https://yoursite.com/sitemap";
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />

        <title>{pageTitle}</title>
        <meta name="description" content={pageDescription} />
        <link rel="canonical" href={canonicalUrl} />

        <meta name="robots" content="index, follow" />

        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content={pageDescription} />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:type" content="website" />

        <meta name="twitter:card" content="summary" />
        <meta name="twitter:title" content={pageTitle} />
        <meta name="twitter:description" content={pageDescription} />
    </head>

    <div>
        <h1>All Subjects, Years, Papers, Notes & Questions</h1>

        <p>
            Browse all subjects, years, past papers, notes, and topic-based
            questions. This page lists everything available for exam preparation
            across boards.
        </p>

        {
            Object.entries(index).map(([board, subjects]) => (
                <div>
                    <h2>{format(board)}</h2>

                    {Object.entries(subjects).map(([subject, subjectData]) => {
                        const subjectName = format(subject);

                        return (
                            <div>
                                <h3>{subjectName}</h3>

                                {/* Subject landing */}
                                <a href={`/subjects/${board}/${subject}`}>
                                    View {subjectName}
                                </a>

                                {/* ================= PAPERS ================= */}
                                <h4>Papers</h4>
                                <ul>
                                    {Object.entries(
                                        subjectData.years ?? {},
                                    ).map(([year, yearData]) => (
                                        <li>
                                            <a
                                                href={`/subjects/${board}/${subject}/${year}`}
                                            >
                                                {subjectName} {year}
                                            </a>

                                            <ul>
                                                {Object.entries(
                                                    yearData?.papers ?? {},
                                                ).map(
                                                    ([
                                                        paperSlug,
                                                        paperData,
                                                    ]) => {
                                                        const paperName =
                                                            paperData?.name ??
                                                            format(paperSlug);

                                                        return (
                                                            <li>
                                                                <a
                                                                    href={`/subjects/${board}/${subject}/${year}/${paperSlug}`}
                                                                >
                                                                    {
                                                                        subjectName
                                                                    }{" "}
                                                                    {year}{" "}
                                                                    {paperName}
                                                                </a>
                                                            </li>
                                                        );
                                                    },
                                                )}
                                            </ul>
                                        </li>
                                    ))}
                                </ul>

                                {/* ================= TOPICS / NOTES / QUESTIONS ================= */}
                                {(subjectData.topics ?? []).length > 0 && (
                                    <div>
                                        <h4>Topics</h4>

                                        <ul>
                                            {(subjectData.topics ?? []).map(
                                                (topic) => {
                                                    const topicName =
                                                        topic.name;
                                                    const topicSlug =
                                                        topic.slug;

                                                    return (
                                                        <li>
                                                            {/* Topic landing (notes default) */}
                                                            <a
                                                                href={`/notes/${board}/${subject}/${topicSlug}`}
                                                            >
                                                                {topicName}
                                                            </a>

                                                            <ul>
                                                                {/* Notes landing */}
                                                                <li>
                                                                    <a
                                                                        href={`/notes/${board}/${subject}/${topicSlug}`}
                                                                    >
                                                                        Notes -{" "}
                                                                        {
                                                                            topicName
                                                                        }
                                                                    </a>
                                                                </li>

                                                                {/* Questions landing */}
                                                                <li>
                                                                    <a
                                                                        href={`/questions/${board}/${subject}/${topicSlug}`}
                                                                    >
                                                                        Questions
                                                                        -{" "}
                                                                        {
                                                                            topicName
                                                                        }
                                                                    </a>
                                                                </li>

                                                                {/* Individual Notes */}
                                                                {(
                                                                    topic.notes ??
                                                                    []
                                                                ).map(
                                                                    (note) => (
                                                                        <li>
                                                                            <a
                                                                                href={`/notes/${board}/${subject}/${topicSlug}/${note.slug}`}
                                                                            >
                                                                                {
                                                                                    note.name
                                                                                }
                                                                            </a>
                                                                        </li>
                                                                    ),
                                                                )}

                                                                {/* Individual Questions (final endpoints) */}
                                                                {(
                                                                    topic.questions ??
                                                                    []
                                                                ).map((q) => {
                                                                    // @ts-ignore
                                                                    const qSlug =
                                                                        q.slug ||
                                                                        q.uuid; // fallback to uuid if slug missing
                                                                    const qName =
                                                                        q.name ||
                                                                        qSlug;

                                                                    if (!qSlug)
                                                                        return null;

                                                                    return (
                                                                        <li>
                                                                            <a
                                                                                href={`/questions/${board}/${subject}/${topicSlug}/${qSlug}`}
                                                                            >
                                                                                {
                                                                                    qName
                                                                                }
                                                                            </a>
                                                                        </li>
                                                                    );
                                                                })}
                                                            </ul>
                                                        </li>
                                                    );
                                                },
                                            )}
                                        </ul>
                                    </div>
                                )}
                            </div>
                        );
                    })}
                </div>
            ))
        }
    </div>


</html>
