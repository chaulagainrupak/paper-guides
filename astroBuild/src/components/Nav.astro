
---
---

<nav class="bg-[var(--color-nav)] fixed top-0 w-full z-50 shadow-sm h-16">
  <div class="flex justify-between items-center px-6 py-4 text-2xl font-bold h-full">
    <a href="/" class="text-xl sm:text-2xl">
      Paper-<span class="text-[var(--blue-highlight)]">Guides</span>
    </a>

    <!-- Desktop links -->
    <div class="gap-4 hidden xl:flex">
      <a href="/pastpapers">Past Papers</a>
      <a href="/notes">Notes</a>
      <a href="/generator">Question Generator</a>
    </div>

    <div class="gap-4 hidden xl:flex items-center">
      <!-- Login link — hydrated client-side -->
      <div id="nav-login-slot"></div>

      <a href="/about" class="text-[var(--pink-highlight)]">About</a>
    </div>

    <!-- Mobile hamburger -->
    <div class="xl:hidden relative">
      <input type="checkbox" id="hamburger" class="peer hidden" />
      <label for="hamburger" class="cursor-pointer text-3xl select-none">&#9776;</label>

      <div
        class="bg-[var(--color-nav)] absolute right-0 top-16 w-52 shadow-lg border rounded-lg p-4 flex-col gap-3 hidden peer-checked:flex"
      >
        <a href="/pastpapers">Past Papers</a>
        <a href="/notes">Notes</a>
        <a href="/generator">Question Generator</a>
        <div id="nav-login-slot-mobile"></div>
        <a href="/about" class="text-[var(--pink-highlight)]">About</a>
      </div>
    </div>
  </div>
</nav>

<!-- Inject login/logout link based on localStorage -->
<script>
  import { isLoggedIn, logOut } from '../utils/auth';

  async function renderLoginLink(slotId: string) {
    const slot = document.getElementById(slotId);
    if (!slot) return;

    const loggedIn = await isLoggedIn();

    if (!loggedIn) {
      slot.innerHTML = '<a href="/login" class="font-bold">Login</a>';
    } else {
      const btn = document.createElement('button');
      btn.textContent = 'Log-Out';
      btn.className = 'cursor-pointer font-bold';
      btn.addEventListener('click', () => {
        logOut();
        window.location.reload();
      });
      slot.appendChild(btn);
    }
  }

  renderLoginLink('nav-login-slot');
  renderLoginLink('nav-login-slot-mobile');
</script>

